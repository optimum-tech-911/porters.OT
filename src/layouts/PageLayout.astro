---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  seo: {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    noindex?: boolean;
    structuredData?: Record<string, unknown>;
  };
  breadcrumbs?: BreadcrumbItem[];
  /** If true, hide breadcrumbs (e.g. on homepage) */
  noBreadcrumbs?: boolean;
}

const { seo, breadcrumbs = [], noBreadcrumbs = false } = Astro.props;
---

<BaseLayout seo={seo}>
  <SiteHeader slot="header" />
  {!noBreadcrumbs && breadcrumbs.length > 0 && (
    <Breadcrumbs items={breadcrumbs} />
  )}
  <slot />
  <SiteFooter slot="footer" />
</BaseLayout>
