---
import PageLayout from '../layouts/PageLayout.astro';
import { pageSeo } from '../data/seo.data';

const functions = [
  {
    number: '01',
    title: 'Conseil et cadrage',
    description: 'Comprendre votre situation, répondre aux questions de statut et préparer un démarrage sans zone grise.',
  },
  {
    number: '02',
    title: 'Contrats et conformité',
    description: 'Organiser la relation tripartite et rendre lisibles les engagements du consultant, du client et de The Porters.',
  },
  {
    number: '03',
    title: 'Facturation et paie',
    description: 'Suivre les éléments d’activité, la facturation, les frais admissibles et la transformation du chiffre d’affaires en salaire.',
  },
  {
    number: '04',
    title: 'Suivi de mission',
    description: 'Rester disponible pendant la mission pour traiter les questions administratives et anticiper les étapes suivantes.',
  },
];
---

<PageLayout
  seo={pageSeo.equipe}
  breadcrumbs={[{ label: 'The Porters', href: '/qui-sommes-nous' }, { label: 'Notre équipe' }]}
>
  <section class="section pt-8 lg:pt-16 pb-20">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Des interlocuteurs, pas une plateforme anonyme</p>
        <h1 class="mb-4">Une équipe présente quand la mission en a <span class="gold-underline">besoin</span></h1>
        <p class="text-porters-black/60 max-w-2xl mx-auto text-lg">
          Du premier échange au suivi administratif, chaque sujet est pris en charge par une fonction clairement identifiée.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        {functions.map((item) => (
          <div class="card p-7 reveal">
            <p class="mb-5 font-heading text-sm font-semibold text-porters-gold">{item.number}</p>
            <h2 class="mb-3 text-xl text-porters-navy">{item.title}</h2>
            <p class="mb-0 text-sm leading-relaxed text-porters-black/60">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-porters-navy/[0.02] border-y border-porters-navy/5 py-16">
    <div class="container mx-auto px-6 lg:px-8 text-center reveal">
      <h2 class="mb-6">Vous aimez rendre les sujets complexes plus simples ?</h2>
      <p class="text-porters-black/60 max-w-xl mx-auto mb-8">
        Découvrez les métiers et les opportunités publiées par The Porters.
      </p>
      <a href="/recrutement" class="btn btn-primary">
        Voir nos offres
      </a>
    </div>
  </section>
</PageLayout>
