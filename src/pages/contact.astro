---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/forms/ContactForm';
import { agencies } from '../data/agencies.data';
import { pageSeo } from '../data/seo.data';
import contactImage from '../../images/enterprise-collaboration.webp';
---

<PageLayout
  seo={pageSeo.contact}
  breadcrumbs={[{ label: 'Contact' }]}
>
  <section class="section pt-8 lg:pt-16 pb-20">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="mb-16 grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(18rem,0.62fr)] lg:items-center">
        <div class="reveal">
          <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Une question précise, une réponse humaine</p>
          <h1 class="mb-4">Parlons de votre <span class="gold-underline">situation</span></h1>
          <p class="text-porters-black/60 max-w-2xl text-lg leading-relaxed">
            Mission déjà trouvée, statut à comparer, simulation à relire ou besoin d’expertise : donnez-nous le contexte utile pour préparer une réponse concrète.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="pill">Mission et statut</span>
            <span class="pill">Simulation et frais</span>
            <span class="pill">Besoin d’expertise</span>
          </div>
        </div>
        <div class="reveal overflow-hidden rounded-lg border border-porters-navy/10 bg-white shadow-[0_18px_50px_rgba(25,43,99,0.08)]">
          <img
            src={contactImage.src}
            width={contactImage.width}
            height={contactImage.height}
            alt="Échange professionnel dans un bureau lumineux."
            class="h-72 w-full object-cover lg:h-80"
          />
        </div>
      </div>

      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 max-w-6xl mx-auto">
        <!-- Contact Form -->
        <div class="lg:col-span-3 reveal">
          <div class="card p-8 lg:p-10">
            <h2 class="text-2xl font-heading font-semibold text-porters-navy mb-8">Expliquez-nous où vous en êtes</h2>
            <ContactForm client:visible />
          </div>
        </div>

        <!-- Contact Info & Agencies -->
        <div class="lg:col-span-2 space-y-12 reveal">
          <div>
            <h3 class="text-xl font-heading font-semibold text-porters-navy mb-6">Contact général</h3>
            <div class="space-y-4 text-porters-black/70">
              <div class="flex items-start gap-4">
                <svg class="w-6 h-6 text-porters-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                <div>
                  <p class="font-medium text-porters-navy">Email</p>
                  <a href="mailto:contact@porters.fr" class="hover:text-porters-gold transition-colors">contact@porters.fr</a>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-heading font-semibold text-porters-navy mb-6">Nos agences</h3>
            <div class="space-y-6">
              {agencies.map((agency) => (
                <div class="border-l-2 border-porters-gold/30 pl-4">
                  <a href={`/agences/${agency.slug}`} class="font-heading font-semibold text-porters-navy hover:text-porters-gold transition-colors block mb-1">
                    The Porters {agency.city}
                  </a>
                  <p class="text-sm text-porters-black/60 mb-2">
                    {agency.address && agency.postalCode
                      ? `${agency.address}, ${agency.postalCode} ${agency.city}`
                      : 'Rendez-vous à distance ou selon les modalités confirmées par l’équipe.'}
                  </p>
                  <div class="flex items-center gap-4 text-sm">
                    {agency.phone && (
                      <a href={`tel:${agency.phone.replace(/\s+/g, '')}`} class="text-porters-navy hover:text-porters-gold transition-colors">{agency.phone}</a>
                    )}
                    {agency.phone && <span class="text-porters-black/20">|</span>}
                    <a href={`mailto:${agency.email}`} class="text-porters-navy hover:text-porters-gold transition-colors">{agency.email}</a>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-6">
              <a href="/agences" class="text-sm font-medium text-porters-navy hover:text-porters-gold transition-colors inline-flex items-center gap-1">
                Voir toutes nos agences
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
