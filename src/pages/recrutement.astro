---
import PageLayout from '../layouts/PageLayout.astro';
import { pageSeo } from '../data/seo.data';
---

<PageLayout
  seo={pageSeo.recrutement}
  breadcrumbs={[{ label: 'The Porters', href: '/qui-sommes-nous' }, { label: 'Recrutement' }]}
>
  <section class="section pt-8 lg:pt-16 pb-12">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Rejoignez-nous</p>
        <h1 class="mb-4">Participez à <span class="gold-underline">l'aventure</span></h1>
        <p class="text-porters-black/60 max-w-2xl mx-auto text-lg">
          The Porters recherche de nouveaux talents pour accompagner sa croissance et réinventer le portage salarial.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <!-- Why join us -->
        <div class="grid md:grid-cols-2 gap-8 mb-16 reveal">
          <div class="card p-8 bg-porters-navy/[0.02]">
            <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-porters-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.36c-5.91.05-8.36-4.94-5.07-9.28C4.18 5.31 13.71 4.4 17.16 8c2.11 2.2 1.03 5.53-1.57 6.37z" /></svg>
            </div>
            <h3 class="font-heading font-semibold text-porters-navy mb-3">Un cadre stimulant</h3>
            <p class="text-sm text-porters-black/60">Rejoignez une équipe dynamique, dans des locaux modernes en plein cœur de ville. Télétravail régulier possible.</p>
          </div>
          <div class="card p-8 bg-porters-navy/[0.02]">
            <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-porters-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>
            </div>
            <h3 class="font-heading font-semibold text-porters-navy mb-3">Évolution rapide</h3>
            <p class="text-sm text-porters-black/60">Une entreprise en forte croissance offrant de réelles opportunités d'évolution en interne.</p>
          </div>
        </div>

        <!-- Open positions -->
        <div class="text-center bg-white border border-porters-navy/10 rounded-2xl p-12 reveal">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-porters-navy/5 mb-6">
            <svg class="w-8 h-8 text-porters-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
          </div>
          <h2 class="text-2xl font-heading font-semibold text-porters-navy mb-4">Nos offres actuelles</h2>
          <p class="text-porters-black/60 mb-8 max-w-lg mx-auto">
            Retrouvez les postes ouverts et les offres mises à jour de The Porters directement sur notre espace HelloWork.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="https://www.hellowork.com/fr-fr/entreprises/the-porters-171310.html" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              Voir les offres sur HelloWork
            </a>
            <a href="/contact" class="btn btn-secondary">Candidature spontanée</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
