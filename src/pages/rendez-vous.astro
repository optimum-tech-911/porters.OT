---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/forms/ContactForm';
import { pageSeo } from '../data/seo.data';

const seo = {
  title: pageSeo.rendezVous.title,
  description: pageSeo.rendezVous.description,
};

const breadcrumbs = [{ label: 'Parler à un conseiller' }];

const meetingTypes = [
  {
    title: 'Découvrir le portage salarial',
    duration: '30 min',
    description: 'Comprendre le statut, les contrats, la protection sociale et les premières étapes.',
  },
  {
    title: 'Optimiser mon salaire',
    duration: '45 min',
    description: 'Relire votre TJM, vos jours facturés, vos frais professionnels et votre simulation.',
  },
  {
    title: 'Passer de freelance à portage',
    duration: '45 min',
    description: 'Comparer micro-entreprise, SASU/EURL et portage salarial selon votre situation.',
  },
  {
    title: 'Discuter de ma mission IT',
    duration: '45 min',
    description: 'Cadrer une mission cyber, data, IA, DevOps, cloud, agilité ou projet IT.',
  },
  {
    title: 'Échanger avec une agence',
    duration: '30 min',
    description: 'Préparer un échange avec un point de contact documenté ou organiser un rendez-vous à distance.',
  },
];

const reasons = [
  {
    icon: '30 min',
    title: 'Un premier échange clair',
    description: 'Expliquez votre situation, vos objectifs et vos questions. Nous vous orientons vers le format d’échange adapté.',
  },
  {
    icon: 'Suivi',
    title: 'Un conseiller dédié',
    description: 'Vous échangez avec un interlocuteur unique qui comprend votre situation et vos objectifs.',
  },
  {
    icon: 'Sur-mesure',
    title: 'Une réponse personnalisée',
    description: 'Que vous soyez consultant ou entreprise, nous revenons vers vous avec des prochaines étapes concrètes.',
  },
];
---

<PageLayout seo={seo} breadcrumbs={breadcrumbs}>

  <!-- Hero -->
  <section class="section bg-porters-navy text-porters-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-porters-white text-[1.85rem] leading-[1.06] sm:text-[3rem] mb-6 max-w-[16rem] sm:max-w-3xl mx-auto">
          Un échange utile commence par <span class="gold-underline">la bonne question</span>
        </h1>
        <p class="text-base sm:text-lg max-w-[18rem] sm:max-w-2xl mx-auto" style="color: rgba(250, 248, 243, 0.85);">
          Statut, simulation, mission IT ou besoin d’entreprise : choisissez votre sujet pour parler directement de votre situation.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)] gap-8 lg:gap-12 max-w-6xl mx-auto">
        <div class="reveal">
          <div class="card p-5 sm:p-8 lg:p-10">
            <div class="mb-8">
              <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-3">Demande de rendez-vous</p>
              <h2 class="text-xl sm:text-2xl font-heading font-semibold text-porters-navy mb-3">
                De quoi avez-vous besoin maintenant ?
              </h2>
              <p class="text-porters-black/65 mb-0">
                Choisissez le sujet, puis indiquez vos coordonnées et vos disponibilités. Un conseiller vous confirme le créneau et prépare l'échange avec les bonnes informations.
              </p>
            </div>
            <div class="grid gap-3 mb-8">
              {meetingTypes.map((type) => (
                <label class="flex cursor-pointer items-start gap-4 rounded-lg border border-porters-navy/10 bg-porters-navy/[0.02] p-4 transition-colors hover:border-porters-gold/50">
                  <input type="radio" name="meetingTypePreview" class="mt-1" />
                  <span>
                    <span class="block font-heading font-semibold text-porters-navy">{type.title}</span>
                    <span class="mt-1 block text-xs font-semibold uppercase tracking-[0.14em] text-porters-gold">{type.duration}</span>
                    <span class="mt-2 block text-sm leading-relaxed text-porters-black/60">{type.description}</span>
                  </span>
                </label>
              ))}
            </div>
            <ContactForm client:visible />
          </div>
        </div>

        <div class="space-y-6 reveal">
          <div class="card p-6 sm:p-7 bg-porters-navy text-porters-white border-porters-navy">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-porters-gold mb-3">
              Ce que vous obtenez
            </p>
            <ul class="space-y-4 text-sm text-porters-white/80">
              <li>Une lecture claire de votre situation et des options possibles.</li>
              <li>Une estimation de revenus ou un cadrage de collaboration si besoin.</li>
              <li>Un interlocuteur humain qui vous suit jusqu'à la prochaine étape.</li>
            </ul>
          </div>

          <div class="card p-6 sm:p-7">
            <h3 class="text-lg font-heading font-semibold text-porters-navy mb-4">
              Besoin d'une réponse rapide ?
            </h3>
            <div class="space-y-4 text-porters-black/70">
              <div>
                <p class="text-sm font-medium text-porters-navy mb-1">Délai de réponse</p>
                <p class="mb-0">Le délai et le format de l’échange sont confirmés après réception de votre demande.</p>
              </div>
              <div>
                <p class="text-sm font-medium text-porters-navy mb-1">Par email</p>
                <a href="mailto:contact@porters.fr" class="hover:text-porters-gold transition-colors">contact@porters.fr</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3 reasons -->
  <section class="section" style="background-color: rgba(25, 43, 99, 0.03);">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2>Un rendez-vous pour <span class="gold-underline">sortir avec des réponses</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {reasons.map((reason) => (
          <div class="text-center reveal">
            <div class="inline-flex items-center justify-center min-w-28 px-4 py-2 rounded-full bg-porters-gold/12 text-porters-navy font-heading font-semibold mb-4">
              {reason.icon}
            </div>
            <h3 class="text-lg font-heading font-semibold mb-2">{reason.title}</h3>
            <p class="text-sm" style="color: rgba(11, 16, 32, 0.7);">{reason.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</PageLayout>
