---
import PageLayout from '../layouts/PageLayout.astro';
import { faqGroups } from '../data/faq.data';
import { pageSeo } from '../data/seo.data';

// Create structured data for FAQ
const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqGroups.flatMap(group => 
    group.items.map(q => ({
      '@type': 'Question',
      name: q.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: q.answer
      }
    }))
  )
};

const seo = {
  ...pageSeo.faq,
  structuredData: faqStructuredData
};
---

<PageLayout
  seo={seo}
  breadcrumbs={[{ label: 'FAQ' }]}
>
  <section class="section pt-8 lg:pt-16 pb-20">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Comprendre le portage</p>
        <h1 class="mb-4">Les réponses avant <span class="gold-underline">les décisions</span></h1>
        <p class="text-porters-black/60 max-w-2xl mx-auto text-lg">
          Statut, contrats, revenus, frais, missions et entreprises : commencez par le sujet qui bloque votre avancée.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-16">
        {faqGroups.map((group) => (
          <div id={group.slug} class="reveal scroll-mt-28">
            <h2 class="text-2xl font-heading font-semibold text-porters-navy mb-6">{group.title}</h2>
            <div class="space-y-4">
              {group.items.map((faq) => (
                <details class="group bg-white border border-porters-navy/10 rounded-lg overflow-hidden cursor-pointer">
                  <summary class="flex justify-between items-center font-medium cursor-pointer list-none p-5 text-porters-navy hover:text-porters-gold transition-colors">
                    <span>{faq.question}</span>
                    <span class="transition group-open:rotate-180 shrink-0 ml-4">
                      <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                    </span>
                  </summary>
                  <div class="text-porters-black/70 mt-0 p-5 pt-0 leading-relaxed border-t border-porters-navy/5">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-20 p-8 lg:p-12 bg-porters-navy text-center rounded-2xl reveal">
        <h3 class="text-2xl font-heading font-semibold text-porters-white mb-4">Vous n'avez pas trouvé votre réponse ?</h3>
        <p class="text-porters-white/70 max-w-xl mx-auto mb-8">
          Notre équipe est à votre disposition pour répondre à toutes vos questions spécifiques.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/contact" class="btn btn-gold">Contactez-nous</a>
          <a href="/rendez-vous" class="btn btn-white border-none">Parler à un conseiller</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
