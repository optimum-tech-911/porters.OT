---
import PageLayout from '../layouts/PageLayout.astro';
import SiteIcon from '../components/ui/SiteIcon.astro';
import { pageSeo } from '../data/seo.data';
import { enterpriseBenefits } from '../data/benefits.data';
import enterpriseHeroImage from '../../images/team-workshop.webp';
import collaborationImage from '../../images/business-meeting.webp';
import { enterprisePage } from '../content/pages/entreprises';

const seo = {
  title: pageSeo.entreprises.title,
  description: pageSeo.entreprises.description,
};

const breadcrumbs = [{ label: 'Entreprises' }];

const painPoints = [
  {
    icon: 'scale',
    title: 'Un cadre à sécuriser',
    description: 'La mission doit préciser les responsabilités, les livrables, la durée et les conditions d’intervention de l’expert.',
  },
  {
    icon: 'alert',
    title: 'Des responsabilités à clarifier',
    description: 'L’autonomie du consultant et le rôle de chaque partie doivent être cohérents avec le fonctionnement réel de la mission.',
  },
  {
    icon: 'document',
    title: 'Une gestion à simplifier',
    description: 'Contrats, facturation et suivi administratif ne doivent pas disperser vos équipes internes.',
  },
  {
    icon: 'search',
    title: 'Une expertise à bien qualifier',
    description: 'Le bon profil dépend du résultat attendu, du contexte technique, du calendrier et du niveau de responsabilité.',
  },
];

const enterpriseProofs = [
  { value: '01', label: 'besoin qualifié' },
  { value: '02', label: 'cadre choisi' },
  { value: '03', label: 'mission contractualisée' },
  { value: '04', label: 'exécution suivie' },
];

const engagementModels = [
  {
    eyebrow: 'Portage salarial',
    title: 'Le consultant a déjà sa mission',
    description:
      'The Porters met en place le cadre contractuel, salarial et administratif. L’entreprise cliente garde une relation opérationnelle simple, avec une facture unique.',
    points: ['Cadre salarial sécurisé', 'Contrat, paie et facturation pris en charge', 'Interlocuteur dédié pendant la mission'],
  },
  {
    eyebrow: 'Renfort via ESN',
    title: 'Vous cherchez encore le bon profil',
    description:
      'Notre écosystème de partenaires permet d’orienter le besoin vers un modèle ESN lorsque le sourcing et le pilotage du renfort priment sur le portage salarial.',
    points: ['Sourcing IT ciblé', 'Choix du modèle selon le besoin', 'Suivi opérationnel cadré'],
  },
];
---

<PageLayout seo={seo} breadcrumbs={breadcrumbs}>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-porters-navy text-porters-white">
    <div class="absolute inset-0">
      <img
        src={enterpriseHeroImage.src}
        width={enterpriseHeroImage.width}
        height={enterpriseHeroImage.height}
        alt=""
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(25,43,99,0.96)_0%,rgba(25,43,99,0.85)_46%,rgba(25,43,99,0.42)_76%,rgba(25,43,99,0.1)_100%)]"></div>
    </div>
    <div class="container relative mx-auto px-6 py-20 lg:px-8 lg:py-28">
      <div class="max-w-2xl reveal">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Solutions entreprises</p>
        <h1 class="mb-6 max-w-[40rem] text-porters-white">
          Une expertise externe. <span class="gold-underline">Un cadre maîtrisé.</span>
        </h1>
        <p class="mb-8 max-w-xl text-lg leading-relaxed text-porters-white/84">
          Faites intervenir un consultant IT, data, cyber, cloud ou transformation sans ajouter une relation d’emploi directe à gérer.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/contact" class="btn btn-gold">Déposer un besoin</a>
          <a href="/rendez-vous" class="btn btn-white">Parler à l’équipe</a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-porters-navy/10 bg-white">
    <div class="container mx-auto grid grid-cols-2 px-6 lg:grid-cols-4 lg:px-8">
      {enterpriseProofs.map((proof) => (
        <div class="border-porters-navy/10 px-3 py-7 text-center even:border-l lg:border-l lg:first:border-l-0 lg:px-6 reveal">
          <p class="mb-1 font-heading text-xl font-bold text-porters-navy sm:text-2xl">{proof.value}</p>
          <p class="mb-0 text-xs font-semibold uppercase tracking-[0.12em] text-porters-black/50">{proof.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pain points -->
  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="mb-12 grid gap-8 lg:grid-cols-[minmax(0,0.78fr)_minmax(18rem,0.42fr)] lg:items-end">
        <div class="reveal">
          <h2>Une expertise externe ne doit pas créer <span class="gold-underline">une complexité interne</span></h2>
          <p class="mt-4 max-w-2xl" style="color: rgba(11, 16, 32, 0.7);">
            Le portage salarial structure la relation avec un consultant autonome et centralise le volet contractuel et administratif.
          </p>
        </div>
        <div class="reveal overflow-hidden rounded-lg border border-porters-navy/10 bg-white shadow-sm">
          <img
            src={collaborationImage.src}
            width={collaborationImage.width}
            height={collaborationImage.height}
            alt="Préparation financière d'une collaboration avec un consultant indépendant."
            class="h-48 w-full object-cover"
          />
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {painPoints.map((point) => (
          <div class="card reveal">
            <div class="icon-chip mb-5">
              <SiteIcon name={point.icon} />
            </div>
            <h3 class="text-lg font-heading font-semibold mb-2">{point.title}</h3>
            <p class="text-sm mb-0" style="color: rgba(11, 16, 32, 0.7);">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section" style="background-color: rgba(25, 43, 99, 0.03);">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2>Ce que votre entreprise <span class="gold-underline">gagne en lisibilité</span></h2>
        <p class="mt-4 max-w-2xl mx-auto" style="color: rgba(11, 16, 32, 0.7);">
          Un contrat de prestation, une facturation centralisée et un point de contact pour le suivi administratif.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {enterpriseBenefits.map((benefit) => (
          <div class="card reveal">
            <h3 class="text-lg font-heading font-semibold mb-2">{benefit.title}</h3>
            <p class="text-sm mb-0" style="color: rgba(11, 16, 32, 0.7);">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-3xl text-center reveal">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Cas d’usage</p>
        <h2>Des expertises pour les moments où le projet ne peut pas attendre</h2>
        <p class="mt-4 text-porters-black/65">Le besoin peut être technique, fonctionnel ou organisationnel. Le point commun : une mission définie, des responsabilités lisibles et un suivi proportionné.</p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {enterprisePage.useCases.map((useCase) => (
          <article class="card reveal p-6">
            <h3 class="text-lg">{useCase.title}</h3>
            <p class="mb-0 mt-3 text-sm leading-relaxed text-porters-black/64">{useCase.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Engagement model choice -->
  <section class="section bg-porters-navy/[0.03]">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-3xl text-center reveal">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Deux cadres, un besoin bien orienté</p>
        <h2>Deux modèles. <span class="gold-underline">Un choix à faire dès le départ.</span></h2>
        <p class="mt-4 text-porters-black/65">
          Le point de départ n’est pas le statut, mais votre besoin : sécuriser un consultant déjà identifié ou trouver une expertise à mobiliser.
        </p>
      </div>
      <div class="mx-auto grid max-w-5xl gap-6 md:grid-cols-2">
        {engagementModels.map((model) => (
          <article class="card reveal p-7 lg:p-9">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.16em] text-porters-gold">{model.eyebrow}</p>
            <h3 class="mb-3 font-heading text-xl font-semibold text-porters-navy">{model.title}</h3>
            <p class="mb-6 text-sm leading-relaxed text-porters-black/65">{model.description}</p>
            <ul class="space-y-3">
              {model.points.map((point) => (
                <li class="flex items-start gap-3 text-sm text-porters-black/70">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-porters-gold"></span>
                  {point}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2>Du besoin à la mission, <span class="gold-underline">sans zone grise</span></h2>
        <p class="mt-4 max-w-2xl mx-auto" style="color: rgba(11, 16, 32, 0.7);">
          Un processus en quatre étapes pour choisir le bon cadre, contractualiser et suivre la mission.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        {enterprisePage.process.map((step) => (
          <div class="text-center reveal">
            <div class="text-5xl font-heading font-bold text-porters-gold mb-4">{step.number}</div>
            <h3 class="text-lg font-heading font-semibold mb-3">{step.title}</h3>
            <p class="text-sm" style="color: rgba(11, 16, 32, 0.7);">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="section bg-porters-navy text-porters-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-porters-white mb-4">
          Votre besoin est précis ? <span class="gold-underline">Cadrons la collaboration.</span>
        </h2>
        <p class="text-lg mb-8" style="color: rgba(250, 248, 243, 0.8);">
          Qualifions votre besoin, le bon modèle de collaboration et les prochaines étapes.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="btn btn-gold">Déposer un besoin</a>
          <a href="/rendez-vous" class="btn btn-white">Parler à l’équipe</a>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
