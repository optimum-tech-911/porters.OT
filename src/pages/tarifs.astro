---
import PageLayout from '../layouts/PageLayout.astro';
import calculatorImage from '../../images/financial-calculator.webp';

const included = [
  'Gestion du contrat de travail et des éléments de paie',
  'Facturation et suivi administratif de la mission',
  'Déclarations sociales et documents réglementaires',
  'Interlocuteur dédié pendant toute la mission',
  'Accès au simulateur et lecture personnalisée du résultat',
  'Accompagnement des frais professionnels au réel',
];
---

<PageLayout
  seo={{
    title: 'Tarifs du portage salarial — The Porters',
    description: 'Frais de gestion The Porters fixés à 10 %, services inclus et prise en compte des frais professionnels réels. Une tarification lisible, sans frais cachés.',
  }}
  breadcrumbs={[{ label: 'Tarifs' }]}
>
  <section class="relative min-h-[38rem] overflow-hidden bg-porters-navy text-porters-white">
    <img
      src={calculatorImage.src}
      width={calculatorImage.width}
      height={calculatorImage.height}
      alt="Calcul transparent d'une rémunération en portage salarial."
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(18,35,48,0.98)_0%,rgba(18,35,48,0.9)_50%,rgba(18,35,48,0.4)_100%)]"></div>
    <div class="container relative mx-auto flex min-h-[38rem] items-center px-6 py-20 lg:px-8">
      <div class="max-w-3xl reveal">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Tarification transparente</p>
        <h1 class="max-w-2xl text-porters-white">10 % de frais de gestion. Tout est lisible.</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-porters-white/78">
          Le taux appliqué dans le simulateur est affiché avant toute prise de contact. Vous voyez le chiffre d'affaires, les frais, les charges estimatives et le net projeté.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="/simulateur" class="btn btn-gold">Calculer mon revenu</a>
          <a href="#inclus" class="btn border-white bg-transparent text-porters-white hover:bg-white hover:text-porters-navy">Voir ce qui est inclus</a>
        </div>
      </div>
    </div>
  </section>

  <section id="inclus" class="section bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1fr)] lg:gap-20">
        <div class="reveal">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Frais de gestion</p>
          <p class="font-heading text-[4.5rem] font-bold leading-none text-porters-navy sm:text-[6.5rem]">10 %</p>
          <p class="mt-5 max-w-md text-lg leading-relaxed text-porters-black/66">
            Un taux unique utilisé pour votre estimation. La simulation reste indicative jusqu'à l'étude de votre situation et de votre convention de portage.
          </p>
        </div>
        <div class="reveal">
          <h2 class="mb-8">Ce qui est inclus dans nos frais</h2>
          <div class="grid gap-x-8 gap-y-5 sm:grid-cols-2">
            {included.map((item) => (
              <div class="flex items-start gap-3 border-b border-porters-navy/10 pb-5">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-porters-gold" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="m5 12 4 4L19 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span class="text-sm font-medium leading-relaxed text-porters-navy">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-porters-navy/[0.03]">
    <div class="container mx-auto grid gap-12 px-6 lg:grid-cols-3 lg:gap-14 lg:px-8">
      <div class="reveal">
        <p class="mb-3 font-mono text-sm font-semibold text-porters-gold">01</p>
        <h3 class="mb-3">Frais professionnels réels</h3>
        <p class="mb-0 text-porters-black/64">Le simulateur propose une base de 500 € par mois. Seules les dépenses professionnelles réelles, justifiées et admissibles sont retenues.</p>
      </div>
      <div class="reveal">
        <p class="mb-3 font-mono text-sm font-semibold text-porters-gold">02</p>
        <h3 class="mb-3">Paie en début de mois</h3>
        <p class="mb-0 text-porters-black/64">Le salaire et les frais validés sont versés dans les cinq premiers jours ouvrés, selon les éléments de paie reçus et les conditions contractuelles.</p>
      </div>
      <div class="reveal">
        <p class="mb-3 font-mono text-sm font-semibold text-porters-gold">03</p>
        <h3 class="mb-3">Avance de trésorerie</h3>
        <p class="mb-0 text-porters-black/64">Lorsque les conditions sont réunies, l'avance évite de faire dépendre votre salaire du délai de règlement final de l'entreprise cliente.</p>
      </div>
    </div>
  </section>

  <section class="bg-porters-navy py-16">
    <div class="container mx-auto flex flex-col gap-7 px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <div class="max-w-2xl reveal">
        <h2 class="mb-2 text-porters-white">Votre simulation, expliquée par un conseiller.</h2>
        <p class="mb-0 text-porters-white/65">Passez du calcul indicatif à une projection adaptée à votre mission.</p>
      </div>
      <a href="/rendez-vous" class="btn btn-gold shrink-0">Prendre rendez-vous</a>
    </div>
  </section>
</PageLayout>
