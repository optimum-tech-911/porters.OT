---
import PageLayout from '../../layouts/PageLayout.astro';
import { agencies } from '../../data/agencies.data';

const featuredAgencySlugs = ['paris', 'lyon', 'aix-en-provence', 'montpellier'];
const featuredAgencies = featuredAgencySlugs
  .map((slug) => agencies.find((agency) => agency.slug === slug))
  .filter(Boolean);
---

<PageLayout
  seo={{
    title: 'Nos agences de portage salarial | The Porters',
    description: 'Découvrez les implantations The Porters à Paris, Lyon, Aix-en-Provence et Montpellier pour un accompagnement de proximité en portage salarial.',
  }}
  breadcrumbs={[{ label: 'Agences' }]}
>
  <section class="section pt-8 lg:pt-16">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h1 class="mb-4">Nos <span class="gold-underline">agences</span> partout en France</h1>
        <p class="text-porters-black/60 max-w-2xl mx-auto text-lg">
          Un accompagnement de proximité pour les consultants IT et tech, avec des coordonnées sensibles publiées uniquement lorsqu'elles sont confirmées.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {featuredAgencies.map((agency) => agency && (
          <a href={`/agences/${agency.slug}`} class="card p-8 group reveal block">
            <p class="text-xs font-semibold uppercase tracking-wider text-porters-gold mb-3">{agency.region}</p>
            <h2 class="text-2xl font-heading font-semibold text-porters-navy mb-4 group-hover:text-porters-gold transition-colors">{agency.city}</h2>
            <p class="text-sm text-porters-black/60 mb-6 leading-relaxed line-clamp-3">
              {agency.description}
            </p>
            <span class="text-sm font-medium text-porters-navy group-hover:text-porters-gold transition-colors inline-flex items-center gap-1">
              Découvrir l'agence
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="mt-20 p-8 lg:p-12 bg-porters-navy/[0.03] rounded-xl text-center reveal border border-porters-navy/5">
        <h3 class="text-xl font-heading font-semibold text-porters-navy mb-4">Vous ne trouvez pas votre ville ?</h3>
        <p class="text-porters-black/60 max-w-xl mx-auto mb-8">
          The Porters accompagne les consultants indépendants et les entreprises sur l'ensemble du territoire national grâce à notre plateforme en ligne et à nos conseillers à distance.
        </p>
        <a href="/contact" class="btn btn-primary">
          Contactez-nous
        </a>
      </div>
    </div>
  </section>
</PageLayout>
