---
import PageLayout from '../layouts/PageLayout.astro';
import HomeHeroCarousel from '../components/home/HomeHeroCarousel';
import heroImage from '../../hero .webp';
import heroImage2 from '../../hero 2.webp';
import heroImage3 from '../../hero 3.webp';
import consultantImage from '../../images/ChatGPT Image 23 juin 2026, 18_50_36 (6).webp';
import enterpriseImage from '../../images/ChatGPT Image 23 juin 2026, 18_50_34 (1).webp';
import simulatorPreviewImage from '../../images/ChatGPT Image 23 juin 2026, 18_50_35 (2).webp';

const heroSlides = [
  {
    label: 'Société de portage salarial',
    titleLines: ['Entreprendre librement,', 'en toute sécurité'],
    description:
      "The Porters accompagne les consultants indépendants et les entreprises dans une relation de confiance. Bénéficiez de la liberté de l'indépendance avec la protection du salariat.",
    mobileDescription:
      "La liberté de l'indépendance, avec la sécurité du salariat et un accompagnement humain.",
    primaryCta: { label: 'Simuler mes revenus', href: '/simulateur' },
    secondaryCta: { label: 'Parler à un conseiller', href: '/rendez-vous' },
    image: heroImage,
    alt: 'Conseillère The Porters au téléphone devant des bureaux modernes.',
    mobileObjectPosition: '72% center',
    desktopObjectPosition: '84% center',
    mobileTitleMaxWidth: '18rem',
    mobileTextMaxWidth: '18rem',
  },
  {
    label: 'SIMULATION & RÉMUNÉRATION',
    titleLines: ["Transformez votre chiffre d'affaires", 'en salaire, sans complexité'],
    description:
      "Estimez vos revenus, comprenez vos frais et avancez avec une vision claire de votre rémunération en portage salarial.",
    mobileDescription:
      "Estimez vos revenus et avancez avec une vision claire de votre rémunération.",
    primaryCta: { label: 'Simuler mon salaire', href: '/simulateur' },
    secondaryCta: { label: 'Comprendre le portage', href: '/portage-salarial' },
    image: heroImage2,
    alt: 'Consultante en rendez-vous professionnel dans un bureau lumineux.',
    mobileObjectPosition: '58% center',
    desktopObjectPosition: 'center center',
    mobileTitleMaxWidth: '18.5rem',
    mobileTextMaxWidth: '17.5rem',
  },
  {
    label: 'ACCOMPAGNEMENT CONSULTANT',
    titleLines: ['Concentrez-vous sur vos missions,', 'The Porters gère le reste'],
    description:
      "Contrats, facturation, bulletins de paie et cadre administratif : vous restez concentré sur votre expertise, avec un accompagnement humain à chaque étape.",
    mobileDescription:
      "Contrats, facturation et paie : restez concentré sur vos missions, nous gérons le reste.",
    primaryCta: { label: 'Prendre rendez-vous', href: '/rendez-vous' },
    secondaryCta: { label: "Découvrir l'accompagnement", href: '/portage-salarial' },
    image: heroImage3,
    alt: 'Consultant concentré devant son ordinateur dans un espace de travail clair.',
    mobileObjectPosition: '64% center',
    desktopObjectPosition: 'center center',
    mobileTitleMaxWidth: '17.5rem',
    mobileTextMaxWidth: '17.5rem',
  },
];
---

<PageLayout
  seo={{
    title: 'The Porters — Société de portage salarial premium en France',
    description: 'The Porters, société de portage salarial premium. Accompagnement personnalisé pour consultants et entreprises à Paris, Lyon et Montpellier. Simulez vos revenus.',
    structuredData: {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'The Porters',
      url: 'https://www.porters.fr',
      description: 'Société de portage salarial premium pour consultants et entreprises en France.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://www.porters.fr/blog?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
  }}
  noBreadcrumbs={true}
>
  <!-- ==========================================
       HERO SECTION
       ========================================== -->
  <HomeHeroCarousel client:load slides={heroSlides} />

  <!-- ==========================================
       TRUST BAR
       ========================================== -->
  <section class="border-y border-porters-navy/8 py-8 sm:py-9 bg-porters-navy/[0.02]">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-x-5 gap-y-8 md:grid-cols-4 md:gap-8 text-center">
        <div class="reveal">
          <p class="text-[1.8rem] sm:text-2xl lg:text-3xl font-heading font-bold text-porters-navy">3</p>
          <p class="text-sm text-porters-black/60 mt-2">Agences en France</p>
        </div>
        <div class="reveal">
          <p class="text-[1.8rem] sm:text-2xl lg:text-3xl font-heading font-bold text-porters-navy">
            <span class="text-porters-gold">+</span>10 ans
          </p>
          <p class="text-sm text-porters-black/60 mt-2">D'expérience</p>
        </div>
        <div class="reveal">
          <p class="text-[1.2rem] sm:text-2xl lg:text-3xl font-heading font-bold text-porters-navy">
            Accompagnement
          </p>
          <p class="text-sm text-porters-black/60 mt-2">Dédié à votre réussite</p>
        </div>
        <div class="reveal">
          <p class="text-[1.2rem] sm:text-2xl lg:text-3xl font-heading font-bold text-porters-navy">
            Transparence
          </p>
          <p class="text-sm text-porters-black/60 mt-2">Sans surprise</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       CONSULTANT VS ENTREPRISE SPLIT
       ========================================== -->
  <section class="section pt-14 lg:pt-16">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-10 lg:mb-14 reveal">
        <h2 class="mb-4">Vous êtes <span class="gold-underline">consultant</span> ou <span class="gold-underline">entreprise</span> ?</h2>
        <p class="text-porters-black/60 max-w-2xl mx-auto">Découvrez comment The Porters vous accompagne selon votre profil.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Consultant card -->
        <div class="card p-0 overflow-hidden reveal group">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={consultantImage.src}
              width={consultantImage.width}
              height={consultantImage.height}
              alt="Consultante indépendante travaillant sur ordinateur dans un bureau lumineux."
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </div>
          <div class="p-8 lg:p-10">
            <div class="w-12 h-12 rounded-lg bg-porters-navy/5 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-porters-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>
            </div>
            <h3 class="text-porters-navy mb-3">Consultants indépendants</h3>
            <p class="text-porters-black/60 mb-6 leading-relaxed">
              Vous souhaitez vous lancer en tant que consultant indépendant ou optimiser votre activité actuelle ? Le portage salarial vous offre la sécurité du salariat avec la liberté de l'entrepreneuriat.
            </p>
            <ul class="space-y-3 mb-8 text-sm text-porters-black/70">
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
                Protection sociale complète
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
                Gestion administrative simplifiée
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
                Accompagnement personnalisé
              </li>
            </ul>
            <a href="/portage-salarial" class="btn btn-ghost group-hover:text-porters-gold">
              Découvrir le portage salarial
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <!-- Enterprise card -->
        <div class="card p-0 overflow-hidden reveal group">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={enterpriseImage.src}
              width={enterpriseImage.width}
              height={enterpriseImage.height}
              alt="Rendez-vous professionnel conclu par une poignée de main."
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </div>
          <div class="p-8 lg:p-10">
            <div class="w-12 h-12 rounded-lg bg-porters-navy/5 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-porters-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5Z" /></svg>
            </div>
            <h3 class="text-porters-navy mb-3">Entreprises</h3>
            <p class="text-porters-black/60 mb-6 leading-relaxed">
              Vous avez besoin de compétences externes spécialisées ? Le portage salarial sécurise vos collaborations avec des consultants indépendants qualifiés, en toute conformité.
            </p>
            <ul class="space-y-3 mb-8 text-sm text-porters-black/70">
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
                Conformité juridique garantie
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
                Simplification administrative
              </li>
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
                Accès aux meilleurs talents
              </li>
            </ul>
            <a href="/entreprises" class="btn btn-ghost group-hover:text-porters-gold">
              Solutions pour entreprises
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       3-STEP PROCESS
       ========================================== -->
  <section class="section bg-porters-navy/[0.02]">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h2 class="mb-4">Du chiffre d'affaires au <span class="gold-underline">salaire</span></h2>
        <p class="text-porters-black/60 max-w-2xl mx-auto">Un processus simple et transparent pour transformer votre activité de consultant en salaire net.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center reveal">
          <div class="w-16 h-16 rounded-full border-2 border-porters-gold flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-heading font-bold text-porters-navy">1</span>
          </div>
          <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3">Trouvez votre mission</h3>
          <p class="text-sm text-porters-black/60 leading-relaxed">
            Vous identifiez vos missions et négociez vos conditions avec l'entreprise cliente. Nous vous accompagnons dans la contractualisation.
          </p>
        </div>

        <div class="text-center reveal">
          <div class="w-16 h-16 rounded-full border-2 border-porters-gold flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-heading font-bold text-porters-navy">2</span>
          </div>
          <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3">Signez votre contrat</h3>
          <p class="text-sm text-porters-black/60 leading-relaxed">
            The Porters établit un contrat de travail en CDI ou CDD. Vous bénéficiez de la protection sociale complète dès le premier jour.
          </p>
        </div>

        <div class="text-center reveal">
          <div class="w-16 h-16 rounded-full border-2 border-porters-gold flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-heading font-bold text-porters-navy">3</span>
          </div>
          <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3">Travaillez sereinement</h3>
          <p class="text-sm text-porters-black/60 leading-relaxed">
            Concentrez-vous sur votre expertise. Nous gérons la facturation, les déclarations, les bulletins de paie et l'accompagnement au quotidien.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       BENEFITS
       ========================================== -->
  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h2 class="mb-4">Pourquoi choisir <span class="gold-underline">The Porters</span></h2>
        <p class="text-porters-black/60 max-w-2xl mx-auto">Un accompagnement premium, transparent et humain pour vous permettre de vous concentrer sur l'essentiel : votre métier.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Protection complète</h4>
          <p class="text-sm text-porters-black/60">Sécurité sociale, mutuelle, prévoyance et cotisations retraite. Vous êtes protégé comme un salarié classique.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Transparence des frais</h4>
          <p class="text-sm text-porters-black/60">Des frais de gestion clairs et compétitifs, sans surprise. Vous savez exactement ce que vous gagnez.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Accompagnement humain</h4>
          <p class="text-sm text-porters-black/60">Un chargé de compte dédié vous accompagne au quotidien. Conseils, suivi administratif et support personnalisé.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Optimisation de revenus</h4>
          <p class="text-sm text-porters-black/60">Bénéficiez de conseils pour optimiser votre rémunération : frais professionnels, épargne salariale, formations.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Proximité locale</h4>
          <p class="text-sm text-porters-black/60">Des agences à Paris, Lyon et Montpellier pour un accompagnement de proximité, avec des interlocuteurs accessibles.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Gestion simplifiée</h4>
          <p class="text-sm text-porters-black/60">Facturation, paie, déclarations sociales et fiscales : nous prenons en charge toute la gestion administrative.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       SIMULATOR PREVIEW
       ========================================== -->
  <section class="section bg-porters-navy/[0.02]">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Simulateur</p>
          <h2 class="mb-6">Estimez vos <span class="gold-underline">revenus</span> en portage salarial</h2>
          <p class="text-porters-black/60 mb-6 leading-relaxed">
            Notre simulateur vous permet d'estimer votre salaire net en fonction de votre taux journalier et de votre volume d'activité. Transparent, simple et immédiat.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3 text-sm text-porters-black/70">
              <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
              Estimation en temps réel
            </li>
            <li class="flex items-start gap-3 text-sm text-porters-black/70">
              <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
              Frais de gestion transparents
            </li>
            <li class="flex items-start gap-3 text-sm text-porters-black/70">
              <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
              Sans engagement
            </li>
          </ul>
          <a href="/simulateur" class="btn btn-primary">
            Accéder au simulateur
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="reveal">
          <div class="overflow-hidden rounded-lg border border-porters-navy/8 bg-white shadow-[0_18px_50px_rgba(25,43,99,0.06)]">
            <img
              src={simulatorPreviewImage.src}
              width={simulatorPreviewImage.width}
              height={simulatorPreviewImage.height}
              alt="Calcul de revenus sur des documents financiers."
              class="h-56 w-full object-cover"
            />
            <div class="p-8 lg:p-10">
            <div class="space-y-6">
              <div>
                <p class="text-xs uppercase tracking-wider text-porters-black/40 mb-1">Taux journalier moyen</p>
                <p class="text-3xl font-heading font-bold text-porters-navy">500 €<span class="text-base font-normal text-porters-black/40"> / jour</span></p>
              </div>
              <div class="h-px bg-porters-navy/8"></div>
              <div>
