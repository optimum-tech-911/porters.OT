---
import PageLayout from '../layouts/PageLayout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import GoogleReviewsBadge from '../components/ui/GoogleReviewsBadge.astro';
import GoogleReviewsMarquee from '../components/ui/GoogleReviewsMarquee.astro';
import SiteIcon from '../components/ui/SiteIcon.astro';
import { faqGroups } from '../data/faq.data';
import { pageSeo } from '../data/seo.data';
import { googleReviewHighlights } from '../content/pages/home';
import { cmsAttrs, cmsText } from '../cms/content';

import presidentVideo from '../../video president porters (1).mp4';

const partnerLogos = [
  { name: 'BPCE', url: '/images/logos/partners/partner-1.png' },
  { name: 'Groupama', url: '/images/logos/partners/partner-2.png' },
  { name: 'Airbus', url: '/images/logos/partners/partner-3.png' },
  { name: 'Safran', url: '/images/logos/partners/partner-4.png' },
  { name: 'Thales', url: '/images/logos/partners/partner-5.png' },
  { name: 'Capgemini', url: '/images/logos/partners/capgemini.svg' },
];

const situations = [
  {
    number: '01',
    key: 'home.journeys.consultant',
    title: cmsText('home.journeys.consultant.title'),
    text: cmsText('home.journeys.consultant.description'),
    href: '/consultants',
    cta: cmsText('home.journeys.consultant.cta'),
  },
  {
    number: '02',
    key: 'home.journeys.it_expert',
    title: cmsText('home.journeys.it_expert.title'),
    text: cmsText('home.journeys.it_expert.description'),
    href: '/portage-salarial',
    cta: cmsText('home.journeys.it_expert.cta'),
  },
  {
    number: '03',
    key: 'home.journeys.enterprise',
    title: cmsText('home.journeys.enterprise.title'),
    text: cmsText('home.journeys.enterprise.description'),
    href: '/entreprises',
    cta: cmsText('home.journeys.enterprise.cta'),
  },
  {
    number: '04',
    key: 'home.journeys.transition',
    title: cmsText('home.journeys.transition.title'),
    text: cmsText('home.journeys.transition.description'),
    href: '/simulateur',
    cta: cmsText('home.journeys.transition.cta'),
  },
];

const offerItems = [
  { key: 'home.offer.human', title: cmsText('home.offer.human.title'), text: cmsText('home.offer.human.description'), icon: 'user' as const },
  { key: 'home.offer.employee', title: cmsText('home.offer.employee.title'), text: cmsText('home.offer.employee.description'), icon: 'shield' as const },
  { key: 'home.offer.admin', title: cmsText('home.offer.admin.title'), text: cmsText('home.offer.admin.description'), icon: 'clipboard' as const },
  { key: 'home.offer.it', title: cmsText('home.offer.it.title'), text: cmsText('home.offer.it.description'), icon: 'network' as const },
];

const supportQuotes = [
  {
    key: 'home.support.chloe',
    quote: cmsText('home.support.chloe.quote'),
    name: cmsText('home.support.chloe.name'),
    role: cmsText('home.support.chloe.role'),
  },
  {
    key: 'home.support.andy',
    quote: cmsText('home.support.andy.quote'),
    name: cmsText('home.support.andy.name'),
    role: cmsText('home.support.andy.role'),
  },
];

const faqPreview = faqGroups.flatMap((group) => group.items).slice(0, 4);
---

<PageLayout seo={pageSeo.home} noBreadcrumbs>
  <HomeHero />

  <section class="light-logo-strip" aria-label="Écosystème professionnel" data-reveal>
    <div class="light-logo-intro">
      <span {...cmsAttrs('home.ecosystem.label')}>{cmsText('home.ecosystem.label')}</span>
    </div>
    <div class="light-logo-marquee auto-marquee" tabindex="0">
      <div class="light-logo-track auto-marquee-track">
        <div class="light-logo-group">
          {partnerLogos.map((logo) => (
            <img src={logo.url} alt={logo.name} loading="lazy" decoding="async" />
          ))}
        </div>
        <div class="light-logo-group" aria-hidden="true">
          {partnerLogos.map((logo) => (
            <img src={logo.url} alt="" loading="lazy" decoding="async" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="light-section light-situations reveal-fade" data-reveal>
    <div class="light-container">
      <div class="light-section-heading reveal-up" data-reveal>
        <p {...cmsAttrs('home.journeys.eyebrow')}>{cmsText('home.journeys.eyebrow')}</p>
        <h2 {...cmsAttrs('home.journeys.title')}>{cmsText('home.journeys.title')}</h2>
        <span {...cmsAttrs('home.journeys.description')}>{cmsText('home.journeys.description')}</span>
      </div>

      <div class="light-situation-grid stagger-children">
        {situations.map((item, index) => (
          <a href={item.href} class="light-situation-card premium-hover reveal-up" data-reveal style={`--reveal-delay: ${index * 90}ms`}>
            <span class="light-card-number">{item.number}</span>
            <h3 {...cmsAttrs(`${item.key}.title`)}>{item.title}</h3>
            <p {...cmsAttrs(`${item.key}.description`)}>{item.text}</p>
            <strong><span {...cmsAttrs(`${item.key}.cta`)}>{item.cta}</span> <span aria-hidden="true">↗</span></strong>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="light-section light-offer-section reveal-fade" data-reveal>
    <div class="light-container light-offer-layout">
      <div class="light-offer-copy reveal-up" data-reveal>
        <p {...cmsAttrs('home.offer.eyebrow')}>{cmsText('home.offer.eyebrow')}</p>
        <h2 {...cmsAttrs('home.offer.title')}>{cmsText('home.offer.title')}</h2>
        <span {...cmsAttrs('home.offer.description')}>{cmsText('home.offer.description')}</span>
        <a href="/portage-salarial"><span {...cmsAttrs('home.offer.cta')}>{cmsText('home.offer.cta')}</span> <span aria-hidden="true">→</span></a>
      </div>
      <div class="light-offer-schema stagger-children" data-offer-schema>
        <div class="light-offer-flow" aria-label="Schéma d’accompagnement The Porters">

        {offerItems.map((item, index) => item && (
          <button
            type="button"
            class:list={['light-offer-item', 'reveal-up', { 'is-active': index === 0 }]}
            data-reveal
            data-offer-step
            data-offer-title={item.title}
            data-offer-text={item.text}
            data-offer-index={`0${index + 1}`}
            style={`--reveal-delay: ${index * 90}ms; --step:${index}`}
          >
            <span>0{index + 1}</span>
            <span class="light-offer-icon"><SiteIcon name={item.icon} class="h-5 w-5" /></span>
            <div>
              <h3 {...cmsAttrs(`${item.key}.title`, 'data-offer-title')}>{item.title}</h3>
              <p {...cmsAttrs(`${item.key}.description`, 'data-offer-text')}>{item.text}</p>
            </div>
          </button>
        ))}
        </div>
        <aside class="light-offer-detail" aria-live="polite">
          <span>01</span>
          <h3 {...cmsAttrs('home.offer.human.title')}>{offerItems[0]?.title}</h3>
          <p {...cmsAttrs('home.offer.human.description')}>{offerItems[0]?.text}</p>
          <a href="/rendez-vous"><span {...cmsAttrs('home.offer.advisor_cta')}>{cmsText('home.offer.advisor_cta')}</span> <b aria-hidden="true">→</b></a>
        </aside>
      </div>
    </div>
  </section>

  <section class="light-section light-hellowork-section reveal-fade" data-reveal>
    <div class="light-container">
      <div class="light-hellowork-card reveal-up" data-reveal>
        <div class="light-hellowork-layout">
          <div class="light-hellowork-copy">
            <p {...cmsAttrs('home.jobs.eyebrow')}>{cmsText('home.jobs.eyebrow')}</p>
            <h2 {...cmsAttrs('home.jobs.title')}>{cmsText('home.jobs.title')}</h2>
            <strong {...cmsAttrs('home.jobs.description')}>{cmsText('home.jobs.description')}</strong>
            <ul class="light-hellowork-points" aria-label="Repères recrutement">
              <li {...cmsAttrs('home.jobs.point.current')}>{cmsText('home.jobs.point.current')}</li>
              <li {...cmsAttrs('home.jobs.point.direct')}>{cmsText('home.jobs.point.direct')}</li>
              <li {...cmsAttrs('home.jobs.point.full')}>{cmsText('home.jobs.point.full')}</li>
            </ul>
            <div>
              <a href="https://www.hellowork.com/fr-fr/entreprises/the-porters-171310.html" target="_blank" rel="noopener noreferrer"><span {...cmsAttrs('home.jobs.external_cta')}>{cmsText('home.jobs.external_cta')}</span> <b aria-hidden="true">→</b></a>
              <a href="/recrutement"><span {...cmsAttrs('home.jobs.internal_cta')}>{cmsText('home.jobs.internal_cta')}</span> <b aria-hidden="true">→</b></a>
            </div>
          </div>
          <div class="light-hellowork-preview" aria-hidden="true">
            <div class="light-hellowork-orbit"></div>
            <article class="light-hellowork-panel light-hellowork-panel--primary">
              <small {...cmsAttrs('home.jobs.preview.platform')}>{cmsText('home.jobs.preview.platform')}</small>
              <strong {...cmsAttrs('home.jobs.preview.company')}>{cmsText('home.jobs.preview.company')}</strong>
              <span {...cmsAttrs('home.jobs.preview.status')}>{cmsText('home.jobs.preview.status')}</span>
            </article>
            <article class="light-hellowork-panel light-hellowork-panel--floating">
              <small {...cmsAttrs('home.jobs.preview.focus')}>{cmsText('home.jobs.preview.focus')}</small>
              <strong {...cmsAttrs('home.jobs.preview.profiles')}>{cmsText('home.jobs.preview.profiles')}</strong>
            </article>
            <div class="light-hellowork-tags">
              <span>Rendez-vous</span>
              <span>RH</span>
              <span>Conseil</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="light-section light-follow-section reveal-fade" data-reveal id="avantages">
    <div class="light-container light-follow-layout">
      <div class="light-follow-copy reveal-up" data-reveal>
        <p {...cmsAttrs('home.support.eyebrow')}>{cmsText('home.support.eyebrow')}</p>
        <div class="light-follow-title">
          <h2 {...cmsAttrs('home.support.title')}>{cmsText('home.support.title')}</h2>
          <span {...cmsAttrs('home.support.title_detail')}>{cmsText('home.support.title_detail')}</span>
        </div>
        <h3 {...cmsAttrs('home.support.subtitle')}>{cmsText('home.support.subtitle')}</h3>
        <span {...cmsAttrs('home.support.description')}>{cmsText('home.support.description')}</span>
        <div class="light-follow-people">
          <strong {...cmsAttrs('home.support.profiles')}>{cmsText('home.support.profiles')}</strong>
        </div>
      </div>

      <div class="light-follow-feature-stack reveal-up" data-reveal style="--reveal-delay: 120ms">
        <figure class="light-follow-feature">
          <span aria-hidden="true">“</span>
          <blockquote {...cmsAttrs('home.support.feature.quote')}>{cmsText('home.support.feature.quote')}</blockquote>
          <figcaption>
            <strong {...cmsAttrs('home.support.feature.name')}>{cmsText('home.support.feature.name')}</strong>
            <span {...cmsAttrs('home.support.feature.role')}>{cmsText('home.support.feature.role')}</span>
          </figcaption>
        </figure>
        <figure class="light-follow-video">
          <div class="light-follow-video-heading">
            <div>
              <p>Le mot du président</p>
              <h3>Une vision du portage, au plus près des talents</h3>
            </div>
            <span aria-hidden="true">▶</span>
          </div>
          <video controls preload="metadata" playsinline aria-label="Le mot du président de The Porters" src={presidentVideo}></video>
        </figure>
      </div>
    </div>

    <div class="light-container light-follow-quotes stagger-children">
      {supportQuotes.map((item, index) => (
        <article class="light-follow-quote reveal-up" data-reveal style={`--reveal-delay: ${220 + index * 100}ms`}>
          <p {...cmsAttrs(`${item.key}.quote`)}>{item.quote}</p>
          <strong {...cmsAttrs(`${item.key}.name`)}>{item.name}</strong>
          <span {...cmsAttrs(`${item.key}.role`)}>{item.role}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="light-section light-reviews reveal-fade" data-reveal>
    <div class="light-container">
      <div class="light-reviews-header reveal-up" data-reveal>
        <div>
          <p {...cmsAttrs('home.reviews.eyebrow')}>{cmsText('home.reviews.eyebrow')}</p>
          <h2 {...cmsAttrs('home.reviews.title')}>{cmsText('home.reviews.title')}</h2>
        </div>
        <GoogleReviewsBadge />
      </div>
      <div class="reveal-fade" data-reveal><GoogleReviewsMarquee reviews={googleReviewHighlights} speed="34s" /></div>
    </div>
  </section>

  <section class="light-section light-faq reveal-fade" data-reveal>
    <div class="light-container light-faq-layout">
      <div class="light-faq-copy reveal-up" data-reveal>
        <p {...cmsAttrs('home.faq.eyebrow')}>{cmsText('home.faq.eyebrow')}</p>
        <h2 {...cmsAttrs('home.faq.title')}>{cmsText('home.faq.title')}</h2>
        <span {...cmsAttrs('home.faq.description')}>{cmsText('home.faq.description')}</span>
        <a href="/faq"><span {...cmsAttrs('home.faq.cta')}>{cmsText('home.faq.cta')}</span> <b aria-hidden="true">→</b></a>
      </div>
      <div class="light-faq-list reveal-up" data-reveal>
        {faqPreview.map((faq) => (
          <details>
            <summary aria-expanded="false">{faq.question}<span aria-hidden="true">+</span></summary>
            <div class="light-faq-answer"><div><p>{faq.answer}</p></div></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="light-final-cta reveal-fade" data-reveal>
    <div class="light-container reveal-scale" data-reveal>
      <p {...cmsAttrs('home.final_cta.eyebrow')}>{cmsText('home.final_cta.eyebrow')}</p>
      <h2 {...cmsAttrs('home.final_cta.title')}>{cmsText('home.final_cta.title')}</h2>
      <span {...cmsAttrs('home.final_cta.description')}>{cmsText('home.final_cta.description')}</span>
      <div>
        <a href="/simulateur" class="light-final-primary" {...cmsAttrs('home.final_cta.simulator')}>{cmsText('home.final_cta.simulator')}</a>
        <a href="/rendez-vous" class="light-final-secondary" {...cmsAttrs('home.final_cta.advisor')}>{cmsText('home.final_cta.advisor')}</a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-offer-schema]').forEach((schema) => {
    const steps = schema.querySelectorAll<HTMLButtonElement>('[data-offer-step]');
    const detail = schema.querySelector<HTMLElement>('.light-offer-detail');
    const detailIndex = detail?.querySelector<HTMLElement>(':scope > span');
    const detailTitle = detail?.querySelector<HTMLElement>('h3');
    const detailText = detail?.querySelector<HTMLElement>('p');

    const selectStep = (step: HTMLButtonElement) => {
      steps.forEach((item) => item.classList.toggle('is-active', item === step));
      if (detailIndex) detailIndex.textContent = step.dataset.offerIndex || '';
      if (detailTitle) detailTitle.textContent = step.dataset.offerTitle || '';
      if (detailText) detailText.textContent = step.dataset.offerText || '';
      detail?.classList.remove('is-switching');
      requestAnimationFrame(() => detail?.classList.add('is-switching'));
    };

    steps.forEach((step) => {
      step.addEventListener('pointerenter', (event) => {
        if (event.pointerType === 'mouse') selectStep(step);
      });
      step.addEventListener('focus', () => selectStep(step));
      step.addEventListener('click', () => selectStep(step));
    });
  });

  document.querySelectorAll('.light-faq-list details').forEach((detail) => {
    const summary = detail.querySelector('summary');
    detail.addEventListener('toggle', () => {
      summary?.setAttribute('aria-expanded', String(detail.hasAttribute('open')));
    });
  });
</script>

<style>
  .light-container {
    width: min(100% - 2.5rem, 78rem);
    margin-inline: auto;
  }

  .light-section {
    padding-block: clamp(5rem, 8vw, 8rem);
  }

  .light-situations {
    padding-top: clamp(4rem, 6vw, 6rem);
  }

  .light-section-heading {
    max-width: 46rem;
    margin-bottom: 3rem;
  }

  .light-section-heading > p,
  .light-offer-copy > p,
  .light-reviews-header p,
  .light-proximity-copy > p,
  .light-faq-copy > p,
  .light-final-cta p {
    margin-bottom: 0.8rem;
    color: var(--color-porters-gold);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .light-section-heading h2,
  .light-offer-copy h2,
  .light-proximity-copy h2,
  .light-faq-copy h2,
  .light-final-cta h2 {
    margin-bottom: 1rem;
    font-size: clamp(2.3rem, 4.4vw, 4.2rem);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .light-section-heading > span,
  .light-proximity-copy > span,
  .light-faq-copy > span,
  .light-final-cta > .light-container > span {
    display: block;
    color: rgba(40, 55, 67, 0.6);
    line-height: 1.7;
  }

  .light-logo-strip {
    display: grid;
    min-height: 7rem;
    grid-template-columns: minmax(15rem, 0.65fr) minmax(0, 1.35fr);
    align-items: center;
    border-block: 1px solid rgba(40, 55, 67, 0.08);
    background: white;
  }

  .light-logo-intro {
    display: flex;
    height: 100%;
    align-items: center;
    padding-inline: clamp(1.5rem, 5vw, 5rem);
    border-right: 1px solid rgba(40, 55, 67, 0.08);
  }

  .light-logo-intro span {
    max-width: 17rem;
    color: rgba(40, 55, 67, 0.58);
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .light-logo-marquee {
    min-width: 0;
    padding-block: 1.5rem;
  }

  .light-logo-track {
    --marquee-duration: 38s;
    gap: 0;
  }

  .light-logo-group {
    display: flex;
    min-width: max-content;
    align-items: center;
    gap: clamp(2.5rem, 5vw, 5rem);
    padding-right: clamp(2.5rem, 5vw, 5rem);
  }

  .light-logo-group img {
    width: clamp(4.5rem, 7vw, 6.5rem);
    max-width: 6.5rem;
    max-height: 2.25rem;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.68;
    transition: opacity var(--motion-fast) ease, transform var(--motion-medium) var(--ease-soft), filter var(--motion-fast) ease;
  }

  .light-logo-group img:hover {
    filter: grayscale(0.25);
    opacity: 0.92;
    transform: scale(1.05);
  }

  .light-situations {
    background: white;
  }

  .light-situation-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(40, 55, 67, 0.14);
  }

  .light-situation-card {
    display: flex;
    min-height: 20rem;
    flex-direction: column;
    padding: 1.6rem;
    border-right: 1px solid rgba(40, 55, 67, 0.12);
    color: var(--color-porters-navy);
    box-shadow: 0 0 0 rgba(40, 55, 67, 0);
    cursor: pointer;
    transition:
      background-color var(--motion-fast) ease,
      border-color var(--motion-fast) ease,
      transform var(--motion-medium) var(--ease-soft),
      box-shadow var(--motion-medium) var(--ease-soft);
  }

  .light-situation-card:first-child {
    border-left: 1px solid rgba(40, 55, 67, 0.12);
  }

  .light-situation-card:hover {
    z-index: 1;
    border-color: rgba(190, 158, 88, 0.62);
    background: #faf7f0;
    box-shadow: 0 22px 50px rgba(40, 55, 67, 0.1);
    transform: translateY(-6px);
  }

  .light-situation-card:focus-visible {
    z-index: 2;
    border-color: var(--color-porters-gold);
    box-shadow: 0 0 0 3px rgba(190, 158, 88, 0.16), 0 22px 50px rgba(40, 55, 67, 0.1);
  }

  .light-card-number,
  .light-offer-item > span,
  .light-city-list a > span {
    color: var(--color-porters-gold);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
  }

  .light-situation-card h3 {
    margin: 3rem 0 1rem;
    font-size: 1.45rem;
  }

  .light-situation-card p {
    color: rgba(40, 55, 67, 0.6);
    font-size: 0.83rem;
    line-height: 1.65;
  }

  .light-situation-card strong {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    color: var(--color-porters-navy);
    font-size: 0.72rem;
  }

  .light-situation-card .light-card-number,
  .light-situation-card strong > span {
    transition: color var(--motion-fast) ease, transform var(--motion-fast) var(--ease-soft);
  }

  .light-situation-card:hover .light-card-number {
    color: var(--color-porters-navy);
  }

  .light-situation-card:hover strong > span,
  .light-situation-card:focus-visible strong > span {
    transform: translate(3px, -3px);
  }

  .light-offer-section {
    background: #f7f4ed;
  }

  .light-offer-layout,
  .light-proximity-layout,
  .light-faq-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(3rem, 8vw, 7rem);
  }

  .light-offer-copy,
  .light-proximity-copy,
  .light-faq-copy {
    align-self: start;
  }

  .light-offer-copy h2,
  .light-proximity-copy h2,
  .light-faq-copy h2 {
    font-size: clamp(2.2rem, 3.6vw, 3.5rem);
  }

  .light-offer-copy > span {
    display: block;
    max-width: 30rem;
    color: rgba(40, 55, 67, 0.62);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .light-offer-copy > a,
  .light-proximity-copy > a,
  .light-faq-copy > a {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
    color: var(--color-porters-navy);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .light-offer-schema {
    display: grid;
    gap: 1.1rem;
  }

  .light-offer-flow {
    position: relative;
    display: grid;
