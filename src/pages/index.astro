---
import PageLayout from '../layouts/PageLayout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import GoogleReviewsBadge from '../components/ui/GoogleReviewsBadge.astro';
import GoogleReviewsMarquee from '../components/ui/GoogleReviewsMarquee.astro';
import SiteIcon from '../components/ui/SiteIcon.astro';
import { faqGroups } from '../data/faq.data';
import { pageSeo } from '../data/seo.data';
import { googleReviewHighlights, homeWhyPorters } from '../content/pages/home';

import advisorDiscussionImg from '../../images/advisor-discussion.webp';
import teamWorkshopImg from '../../images/team-workshop.webp';
import businessMeetingImg from '../../images/business-meeting.webp';

const partnerLogos = [
  { name: 'BPCE', url: '/images/logos/partners/partner-1.png' },
  { name: 'Groupama', url: '/images/logos/partners/partner-2.png' },
  { name: 'Airbus', url: '/images/logos/partners/partner-3.png' },
  { name: 'Safran', url: '/images/logos/partners/partner-4.png' },
  { name: 'Thales', url: '/images/logos/partners/partner-5.png' },
  { name: 'Capgemini', url: '/images/logos/partners/capgemini.svg' },
];

const situations = [
  {
    number: '01',
    title: 'Consultant indépendant',
    text: 'Sécurisez vos missions avec un contrat salarié, une paie lisible et une gestion administrative prise en charge.',
    href: '/consultants',
    cta: 'Parcours consultant',
  },
  {
    number: '02',
    title: 'Expert IT en mission',
    text: 'Transformez une mission déjà négociée en cadre contractuel clair, du TJM jusqu’au démarrage.',
    href: '/portage-salarial',
    cta: 'Cadre du portage',
  },
  {
    number: '03',
    title: 'Entreprise cliente',
    text: 'Intégrez une expertise externe avec un cadre de mission simple, suivi et documenté.',
    href: '/entreprises',
    cta: 'Offre entreprises',
  },
  {
    number: '04',
    title: 'En transition',
    text: 'Comparez vos options, vos revenus cibles et le niveau de gestion que vous souhaitez déléguer.',
    href: '/simulateur',
    cta: 'Simulation revenus',
  },
];

const offerTitles = [
  'Accompagnement humain',
  'Cadre salarié',
  'Cadre administratif suivi',
  'Expertise IT & transformation',
];
const offerItems = offerTitles
  .map((title, index) => {
    const item = homeWhyPorters.find((candidate) => candidate.title === title);
    return item ? { ...item, icon: ['user', 'shield', 'clipboard', 'network'][index] as 'user' | 'shield' | 'clipboard' | 'network' } : undefined;
  })
  .filter(Boolean);

const supportAvatars = [
  { name: 'Conseiller', image: advisorDiscussionImg.src },
  { name: 'Équipe', image: teamWorkshopImg.src },
  { name: 'Réunion', image: businessMeetingImg.src },
];

const supportQuotes = [
  {
    quote: 'Grâce au portage salarial, je me sens plus libre et sécurisée. Les charges sont transparentes, je continue à toucher mes indemnités chômage et retraite.',
    name: 'Chloé',
    role: 'Consultante data en portage — Lyon',
  },
  {
    quote: 'Le jour où j’ai passé le cap du portage salarial, j’ai retrouvé une vraie respiration : je reste indépendant, mais je ne porte plus tout seul l’administratif.',
    name: 'Andy P.',
    role: 'Product manager freelance — Paris',
  },
];

const faqPreview = faqGroups.flatMap((group) => group.items).slice(0, 4);
---

<PageLayout seo={pageSeo.home} noBreadcrumbs>
  <HomeHero />

  <section class="light-logo-strip" aria-label="Écosystème professionnel" data-reveal>
    <div class="light-logo-intro">
      <span>Un écosystème habitué aux projets exigeants</span>
    </div>
    <div class="light-logo-marquee auto-marquee" tabindex="0">
      <div class="light-logo-track auto-marquee-track">
        <div class="light-logo-group">
          {partnerLogos.map((logo) => (
            <img src={logo.url} alt={logo.name} loading="lazy" decoding="async" />
          ))}
        </div>
        <div class="light-logo-group" aria-hidden="true">
          {partnerLogos.map((logo) => (
            <img src={logo.url} alt="" loading="lazy" decoding="async" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="light-section light-situations reveal-fade" data-reveal>
    <div class="light-container">
      <div class="light-section-heading reveal-up" data-reveal>
        <p>Choisir son parcours</p>
        <h2>Un cadre adapté à votre situation professionnelle</h2>
        <span>Identifiez le parcours qui correspond à votre mission, à votre statut et au niveau d’accompagnement attendu.</span>
      </div>

      <div class="light-situation-grid stagger-children">
        {situations.map((item, index) => (
          <a href={item.href} class="light-situation-card premium-hover reveal-up" data-reveal style={`--reveal-delay: ${index * 90}ms`}>
            <span class="light-card-number">{item.number}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <strong>{item.cta} <span aria-hidden="true">↗</span></strong>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="light-section light-offer-section reveal-fade" data-reveal>
    <div class="light-container light-offer-layout">
      <div class="light-offer-copy reveal-up" data-reveal>
        <p>Ce que nous prenons en charge</p>
        <h2>Vous développez votre expertise. Nous rendons le cadre plus simple.</h2>
        <span>Survolez ou sélectionnez une étape pour comprendre comment le suivi s’organise autour de votre mission.</span>
        <a href="/portage-salarial">Découvrir le fonctionnement <span aria-hidden="true">→</span></a>
      </div>
      <div class="light-offer-schema stagger-children" data-offer-schema>
        <div class="light-offer-flow" aria-label="Schéma d’accompagnement The Porters">

        {offerItems.map((item, index) => item && (
          <button
            type="button"
            class:list={['light-offer-item', 'reveal-up', { 'is-active': index === 0 }]}
            data-reveal
            data-offer-step
            data-offer-title={item.title}
            data-offer-text={item.text}
            data-offer-index={`0${index + 1}`}
            style={`--reveal-delay: ${index * 90}ms; --step:${index}`}
          >
            <span>0{index + 1}</span>
            <span class="light-offer-icon"><SiteIcon name={item.icon} class="h-5 w-5" /></span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </button>
        ))}
        </div>
        <aside class="light-offer-detail" aria-live="polite">
          <span>01</span>
          <h3>{offerItems[0]?.title}</h3>
          <p>{offerItems[0]?.text}</p>
          <a href="/rendez-vous">Échanger avec un conseiller <b aria-hidden="true">→</b></a>
        </aside>
      </div>
    </div>
  </section>

  <section class="light-section light-follow-section reveal-fade" data-reveal id="avantages">
    <div class="light-container light-follow-layout">
      <div class="light-follow-copy reveal-up" data-reveal>
        <p>L’accompagnement dans la durée</p>
        <div class="light-follow-title">
          <h2>Suivi</h2>
          <span>humain, contractuel et administratif pendant la mission</span>
        </div>
        <h3>Être indépendant ne veut pas dire être seul</h3>
        <span>Un interlocuteur connaît votre dossier et répond concrètement sur le contrat, la facturation, la paie, les frais et la relation client.</span>
        <div class="light-follow-people">
          <div aria-hidden="true">
            {supportAvatars.map((person) => (
              <img src={person.image} alt="" loading="lazy" decoding="async" />
            ))}
          </div>
          <strong>Profils IT, produit, data et transformation</strong>
        </div>
      </div>

      <figure class="light-follow-feature reveal-up" data-reveal style="--reveal-delay: 120ms">
        <span aria-hidden="true">“</span>
        <blockquote>
          Je voulais devenir indépendante mais je ne souhaitais pas non plus créer ma propre entreprise pour le moment. J’ai entendu parler du portage salarial et j’ai pu me lancer grâce à The Porters. À mi-chemin entre l’indépendance et le salariat, je me sens à la fois libre et accompagnée.
        </blockquote>
        <figcaption>
          <strong>Delphine</strong>
          <span>Product Owner en portage salarial — Paris</span>
        </figcaption>
      </figure>
    </div>

    <div class="light-container light-follow-quotes stagger-children">
      {supportQuotes.map((item, index) => (
        <article class="light-follow-quote reveal-up" data-reveal style={`--reveal-delay: ${220 + index * 100}ms`}>
          <p>« {item.quote} »</p>
          <strong>{item.name}</strong>
          <span>{item.role}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="light-section light-reviews reveal-fade" data-reveal>
    <div class="light-container">
      <div class="light-reviews-header reveal-up" data-reveal>
        <div>
          <p>Avis Google</p>
          <h2>La qualité de service se lit dans les retours</h2>
        </div>
        <GoogleReviewsBadge />
      </div>
      <div class="reveal-fade" data-reveal><GoogleReviewsMarquee reviews={googleReviewHighlights} speed="34s" /></div>
    </div>
  </section>

  <section class="light-section light-faq reveal-fade" data-reveal>
    <div class="light-container light-faq-layout">
      <div class="light-faq-copy reveal-up" data-reveal>
        <p>Questions fréquentes</p>
        <h2>Les réponses avant les décisions</h2>
        <span>Statut, revenus, frais et missions : retrouvez les points essentiels avant d’avancer.</span>
        <a href="/faq">Consulter toute la FAQ <b aria-hidden="true">→</b></a>
      </div>
      <div class="light-faq-list reveal-up" data-reveal>
        {faqPreview.map((faq) => (
          <details>
            <summary aria-expanded="false">{faq.question}<span aria-hidden="true">+</span></summary>
            <div class="light-faq-answer"><div><p>{faq.answer}</p></div></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="light-final-cta reveal-fade" data-reveal>
    <div class="light-container reveal-scale" data-reveal>
      <p>Votre prochaine étape</p>
      <h2>Prêt à donner un nouveau cadre à votre indépendance ?</h2>
      <span>Choisissez vos missions. Nous cadrons les contrats, la facturation, la paie et le suivi administratif.</span>
      <div>
        <a href="/simulateur" class="light-final-primary">Simuler mes revenus</a>
        <a href="/rendez-vous" class="light-final-secondary">Parler à un conseiller</a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-offer-schema]').forEach((schema) => {
    const steps = schema.querySelectorAll<HTMLButtonElement>('[data-offer-step]');
    const detail = schema.querySelector<HTMLElement>('.light-offer-detail');
    const detailIndex = detail?.querySelector<HTMLElement>(':scope > span');
    const detailTitle = detail?.querySelector<HTMLElement>('h3');
    const detailText = detail?.querySelector<HTMLElement>('p');

    const selectStep = (step: HTMLButtonElement) => {
      steps.forEach((item) => item.classList.toggle('is-active', item === step));
      if (detailIndex) detailIndex.textContent = step.dataset.offerIndex || '';
      if (detailTitle) detailTitle.textContent = step.dataset.offerTitle || '';
      if (detailText) detailText.textContent = step.dataset.offerText || '';
      detail?.classList.remove('is-switching');
      requestAnimationFrame(() => detail?.classList.add('is-switching'));
    };

    steps.forEach((step) => {
      step.addEventListener('pointerenter', (event) => {
        if (event.pointerType === 'mouse') selectStep(step);
      });
      step.addEventListener('focus', () => selectStep(step));
      step.addEventListener('click', () => selectStep(step));
    });
  });

  document.querySelectorAll('.light-faq-list details').forEach((detail) => {
    const summary = detail.querySelector('summary');
    detail.addEventListener('toggle', () => {
      summary?.setAttribute('aria-expanded', String(detail.hasAttribute('open')));
    });
  });
</script>

<style>
  .light-container {
    width: min(100% - 2.5rem, 78rem);
    margin-inline: auto;
  }

  .light-section {
    padding-block: clamp(5rem, 8vw, 8rem);
  }

  .light-situations {
    padding-top: clamp(4rem, 6vw, 6rem);
  }

  .light-section-heading {
    max-width: 46rem;
    margin-bottom: 3rem;
  }

  .light-section-heading > p,
  .light-offer-copy > p,
  .light-reviews-header p,
  .light-proximity-copy > p,
  .light-faq-copy > p,
  .light-final-cta p {
    margin-bottom: 0.8rem;
    color: var(--color-porters-gold);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .light-section-heading h2,
  .light-offer-copy h2,
  .light-proximity-copy h2,
  .light-faq-copy h2,
  .light-final-cta h2 {
    margin-bottom: 1rem;
    font-size: clamp(2.3rem, 4.4vw, 4.2rem);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .light-section-heading > span,
  .light-proximity-copy > span,
  .light-faq-copy > span,
  .light-final-cta > .light-container > span {
    display: block;
    color: rgba(40, 55, 67, 0.6);
    line-height: 1.7;
  }

  .light-logo-strip {
    display: grid;
    min-height: 7rem;
    grid-template-columns: minmax(15rem, 0.65fr) minmax(0, 1.35fr);
    align-items: center;
    border-block: 1px solid rgba(40, 55, 67, 0.08);
    background: white;
  }

  .light-logo-intro {
    display: flex;
    height: 100%;
    align-items: center;
    padding-inline: clamp(1.5rem, 5vw, 5rem);
    border-right: 1px solid rgba(40, 55, 67, 0.08);
  }

  .light-logo-intro span {
    max-width: 17rem;
    color: rgba(40, 55, 67, 0.58);
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .light-logo-marquee {
    min-width: 0;
    padding-block: 1.5rem;
  }

  .light-logo-track {
    --marquee-duration: 38s;
    gap: 0;
  }

  .light-logo-group {
    display: flex;
    min-width: max-content;
    align-items: center;
    gap: clamp(2.5rem, 5vw, 5rem);
    padding-right: clamp(2.5rem, 5vw, 5rem);
  }

  .light-logo-group img {
    width: clamp(4.5rem, 7vw, 6.5rem);
    max-width: 6.5rem;
    max-height: 2.25rem;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.68;
    transition: opacity var(--motion-fast) ease, transform var(--motion-medium) var(--ease-soft), filter var(--motion-fast) ease;
  }

  .light-logo-group img:hover {
    filter: grayscale(0.25);
    opacity: 0.92;
    transform: scale(1.05);
  }

  .light-situations {
    background: white;
  }

  .light-situation-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(40, 55, 67, 0.14);
  }

  .light-situation-card {
    display: flex;
    min-height: 20rem;
    flex-direction: column;
    padding: 1.6rem;
    border-right: 1px solid rgba(40, 55, 67, 0.12);
    color: var(--color-porters-navy);
    box-shadow: 0 0 0 rgba(40, 55, 67, 0);
    cursor: pointer;
    transition:
      background-color var(--motion-fast) ease,
      border-color var(--motion-fast) ease,
      transform var(--motion-medium) var(--ease-soft),
      box-shadow var(--motion-medium) var(--ease-soft);
  }

  .light-situation-card:first-child {
    border-left: 1px solid rgba(40, 55, 67, 0.12);
  }

  .light-situation-card:hover {
    z-index: 1;
    border-color: rgba(190, 158, 88, 0.62);
    background: #faf7f0;
    box-shadow: 0 22px 50px rgba(40, 55, 67, 0.1);
    transform: translateY(-6px);
  }

  .light-situation-card:focus-visible {
    z-index: 2;
    border-color: var(--color-porters-gold);
    box-shadow: 0 0 0 3px rgba(190, 158, 88, 0.16), 0 22px 50px rgba(40, 55, 67, 0.1);
  }

  .light-card-number,
  .light-offer-item > span,
  .light-city-list a > span {
    color: var(--color-porters-gold);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
  }

  .light-situation-card h3 {
    margin: 3rem 0 1rem;
    font-size: 1.45rem;
  }

  .light-situation-card p {
    color: rgba(40, 55, 67, 0.6);
    font-size: 0.83rem;
    line-height: 1.65;
  }

  .light-situation-card strong {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    color: var(--color-porters-navy);
    font-size: 0.72rem;
  }

  .light-situation-card .light-card-number,
  .light-situation-card strong > span {
    transition: color var(--motion-fast) ease, transform var(--motion-fast) var(--ease-soft);
  }

  .light-situation-card:hover .light-card-number {
    color: var(--color-porters-navy);
  }

  .light-situation-card:hover strong > span,
  .light-situation-card:focus-visible strong > span {
    transform: translate(3px, -3px);
  }

  .light-offer-section {
    background: #f7f4ed;
  }

  .light-offer-layout,
  .light-proximity-layout,
  .light-faq-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(3rem, 8vw, 7rem);
  }

  .light-offer-copy,
  .light-proximity-copy,
  .light-faq-copy {
    align-self: start;
  }

  .light-offer-copy h2,
  .light-proximity-copy h2,
  .light-faq-copy h2 {
    font-size: clamp(2.2rem, 3.6vw, 3.5rem);
  }

  .light-offer-copy > span {
    display: block;
    max-width: 30rem;
    color: rgba(40, 55, 67, 0.62);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .light-offer-copy > a,
  .light-proximity-copy > a,
  .light-faq-copy > a {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
    color: var(--color-porters-navy);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .light-offer-schema {
    display: grid;
    gap: 1.1rem;
  }

  .light-offer-flow {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    min-height: 25rem;
    padding: clamp(1rem, 2vw, 1.35rem);
    border: 1px solid rgba(40, 55, 67, 0.1);
    border-radius: 8px;
    background:
      radial-gradient(circle at 50% 50%, rgba(190, 158, 88, 0.13), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.64), rgba(255, 255, 255, 0.18));
  }

  .light-offer-flow::before,
  .light-offer-flow::after {
    position: absolute;
    inset: 50% 1.35rem auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(190, 158, 88, 0.46), transparent);
    content: "";
    pointer-events: none;
  }

  .light-offer-flow::after {
    inset: 1.35rem auto 1.35rem 50%;
    width: 1px;
    height: auto;
    background: linear-gradient(180deg, transparent, rgba(190, 158, 88, 0.46), transparent);
  }



  .light-offer-item {
    display: grid;
    grid-template-columns: 2.2rem 2.6rem 1fr;
    align-items: start;
    gap: 1rem;
    min-height: 10.7rem;
    border: 1px solid rgba(40, 55, 67, 0.1);
    border-radius: 8px;
    padding: 1.1rem;
    background: rgba(255, 255, 255, 0.62);
    color: var(--color-porters-navy);
    cursor: pointer;
    font: inherit;
    text-align: left;
    transition:
      transform var(--motion-medium) var(--ease-soft),
      box-shadow var(--motion-medium) ease,
      background-color var(--motion-fast) ease,
      border-color var(--motion-fast) ease;
  }

  .light-offer-item:hover,
  .light-offer-item:focus-visible,
  .light-offer-item.is-active {
    border-color: rgba(190, 158, 88, 0.48);
    background: #fff;
    box-shadow: 0 18px 42px rgba(40, 55, 67, 0.1);
    outline: none;
    transform: translateY(-5px);
  }

  .light-offer-icon {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border: 1px solid rgba(190, 158, 88, 0.4);
    border-radius: 50%;
    color: var(--color-porters-gold);
    transform: scale(0.92);
    transition:
      color var(--motion-fast) ease,
      background-color var(--motion-fast) ease,
      transform var(--motion-medium) var(--ease-soft);
  }

  .light-offer-item:hover .light-offer-icon,
  .light-offer-item:focus-visible .light-offer-icon,
  .light-offer-item.is-active .light-offer-icon {
    background: var(--color-porters-gold);
    color: var(--color-porters-navy);
    transform: scale(1) rotate(-4deg);
  }

  .light-offer-item h3 {
    margin-bottom: 0.45rem;
    font-size: 1.1rem;
  }

  .light-offer-item p {
    margin: 0;
    color: rgba(40, 55, 67, 0.6);
    font-size: 0.8rem;
    line-height: 1.65;
  }

  .light-offer-detail {
    position: relative;
    overflow: hidden;
    min-height: 12rem;
    border: 1px solid rgba(40, 55, 67, 0.1);
    border-radius: 8px;
    padding: clamp(1.25rem, 2vw, 1.8rem);
    background: #fff;
    box-shadow: 0 18px 42px rgba(40, 55, 67, 0.06);
  }

  .light-offer-detail::after {
    position: absolute;
    right: -4rem;
    bottom: -5rem;
    width: 13rem;
    aspect-ratio: 1;
    border: 1px solid rgba(190, 158, 88, 0.24);
    border-radius: 50%;
    content: "";
    pointer-events: none;
  }

  .light-offer-detail > span {
    display: block;
    color: rgba(40, 55, 67, 0.2);
    font: 780 2.6rem/1 var(--font-mono);
  }

  .light-offer-detail h3 {
    margin-top: 0.35rem;
    color: var(--color-porters-navy);
    font-size: clamp(1.35rem, 2vw, 1.85rem);
  }

  .light-offer-detail p {
    max-width: 34rem;
    margin-top: 0.65rem;
    color: rgba(40, 55, 67, 0.64);
    font-size: 0.92rem;
    line-height: 1.7;
