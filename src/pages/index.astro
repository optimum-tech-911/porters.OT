---
import PageLayout from '../layouts/PageLayout.astro';
import HomeHeroCarousel from '../components/home/HomeHeroCarousel';
import LogoMarquee from '../components/ui/LogoMarquee.astro';
import GoogleReviewsBadge from '../components/ui/GoogleReviewsBadge.astro';
import independentHero1Desktop from '../../images/hero/independent-hero-01-desktop.webp';
import independentHero2Desktop from '../../images/hero/independent-hero-02-desktop.webp';
import independentHero3Desktop from '../../images/hero/independent-hero-03-desktop.webp';
import independentHero4Desktop from '../../images/hero/independent-hero-04-desktop.webp';
import independentHero1Mobile from '../../images/hero/independent-hero-01-mobile.webp';
import independentHero2Mobile from '../../images/hero/independent-hero-02-mobile.webp';
import independentHero3Mobile from '../../images/hero/independent-hero-03-mobile.webp';
import independentHero4Mobile from '../../images/hero/independent-hero-04-mobile.webp';
import enterpriseDesktop1 from '../../images/hero/entreprise-desktop-01.webp';
import enterpriseDesktop2 from '../../images/hero/entreprise-desktop-02.webp';
import enterpriseDesktop3 from '../../images/hero/entreprise-desktop-03.webp';
import enterpriseMobile1 from '../../images/hero/entreprise-mobile-01.webp';
import enterpriseMobile2 from '../../images/hero/entreprise-mobile-02.webp';
import pathwayConsultantImage from '../../images/sections/home-pathway-consultant.webp';
import pathwayEnterpriseImage from '../../images/sections/home-pathway-enterprise.webp';
import pathwaySimulationImage from '../../images/sections/home-pathway-simulation.webp';
import simulatorPreviewImage from '../../images/business-meeting.webp';
import { agencies } from '../data/agencies.data';
import { testimonials } from '../data/testimonials.data';
import { blogPosts, getBlogCategory } from '../data/blog.data';

const homepageAgencies = agencies.filter((agency) =>
  ['paris', 'lyon', 'aix-en-provence', 'montpellier'].includes(agency.slug),
);
const homepagePosts = [
  'secteurs-adaptes-portage-salarial',
  'optimiser-remuneration-portage-salarial',
  'role-charge-de-compte-portage-salarial',
]
  .map((slug) => blogPosts.find((post) => post.slug === slug))
  .filter(Boolean);

const partnerNames = [
  'BPCE',
  'Groupama',
  'Airbus',
  'Safran',
  'Thales',
  'CMA CGM',
  'Sopra Steria',
  'Akkodis',
  'Scalian',
  'Inetum',
];
const partnerLogos = partnerNames.map((name, index) => ({
  name,
  url: `/images/logos/partners/partner-${index + 1}.png`,
}));
const row1 = partnerLogos.slice(0, 5);
const row2 = partnerLogos.slice(5, 10);
const testimonialPortraits = [
  {
    image: independentHero2Mobile,
    alt: 'Portrait d’un consultant indépendant dans son environnement de travail.',
    objectPosition: '58% 34%',
  },
  {
    image: enterpriseMobile1,
    alt: 'Professionnelle participant au cadrage d’une mission IT.',
    objectPosition: '24% 28%',
  },
  {
    image: enterpriseMobile2,
    alt: 'Expert IT échangeant avec une équipe projet.',
    objectPosition: '51% 32%',
  },
];
const statusCards = [
  {
    title: 'Portage salarial',
    body: 'Pour exercer en autonomie avec un contrat salarié, une paie structurée et une gestion administrative déléguée.',
  },
  {
    title: 'CDI',
    body: 'Pour les profils qui recherchent un cadre durable, une continuité de mission et une protection sociale complète.',
  },
  {
    title: 'CDD',
    body: 'Pour cadrer une mission limitée dans le temps avec une structure contractuelle claire.',
  },
  {
    title: 'Freelance',
    body: 'Pour comparer les statuts, comprendre les arbitrages et choisir le bon niveau de charge administrative.',
  },
];
const expertiseGroups = [
  'IT & digital',
  'Data / IA',
  'Cybersécurité',
  'Cloud & DevOps',
  'Banque / assurance',
  'Industrie',
  'Aéronautique',
  'Management de projet',
];

const heroAudiences = [
  {
    id: 'consultant' as const,
    tabLabel: 'Je suis indépendant',
    eyebrow: 'Portage salarial · Consultants IT indépendants',
    headline: 'Restez libre. On porte le reste.',
    subhead: 'Cybersécurité, data/IA, DevOps, agilité : vous gardez la mission, nous gérons le contrat, la paie et l’administratif.',
    stat: { value: '+10 ans', label: 'd’accompagnement' },
    primaryCta: { label: 'Simuler mon salaire', href: '/simulateur' },
    secondaryCta: { label: 'Prendre rendez-vous', href: '/rendez-vous' },
    desktopImages: [
      {
        ...independentHero1Desktop,
        alt: 'Deux consultants indépendants analysant ensemble les résultats d’une mission.',
        objectPosition: 'center',
      },
      {
        ...independentHero2Desktop,
        alt: 'Consultant indépendant concentré sur son activité devant son ordinateur.',
        objectPosition: 'center',
      },
      {
        ...independentHero3Desktop,
        alt: 'Consultante indépendante échangeant avec un client dans un bureau contemporain.',
        objectPosition: 'center',
      },
      {
        ...independentHero4Desktop,
        alt: 'Consultante indépendante travaillant sur son ordinateur dans son espace de travail.',
        objectPosition: 'center',
      },
    ],
    mobileImages: [
      {
        ...independentHero1Mobile,
        alt: 'Deux consultants indépendants analysant ensemble les résultats d’une mission.',
        objectPosition: '52% 44%',
      },
      {
        ...independentHero2Mobile,
        alt: 'Consultant indépendant travaillant dans un bureau contemporain.',
        objectPosition: '66% 43%',
      },
      {
        ...independentHero3Mobile,
        alt: 'Consultante indépendante échangeant avec un client.',
        objectPosition: '62% 42%',
      },
      {
        ...independentHero4Mobile,
        alt: 'Consultante indépendante travaillant sur son ordinateur.',
        objectPosition: '55% 42%',
      },
    ],
  },
  {
    id: 'entreprise' as const,
    tabLabel: 'Je suis une entreprise',
    eyebrow: 'Solutions IT · Entreprises',
    headline: 'Le bon consultant IT, sans la lourdeur administrative.',
    subhead: 'Sourcing rapide en France et à l’international, zéro gestion RH, un interlocuteur unique du brief à la fin de mission.',
    stat: { value: '+150', label: 'missions en cours' },
    primaryCta: { label: 'Trouver un consultant', href: '/entreprises' },
    secondaryCta: { label: 'Prendre rendez-vous', href: '/rendez-vous' },
    desktopImages: [
      {
        ...enterpriseDesktop1,
        alt: 'Équipe de professionnels cadrant une mission autour d’un ordinateur.',
        objectPosition: 'center',
      },
      {
        ...enterpriseDesktop2,
        alt: 'Consultants et entreprise réunis dans un bureau lumineux.',
        objectPosition: 'center',
      },
      {
        ...enterpriseDesktop3,
        alt: 'Équipe projet en échange autour d’une mission IT.',
        objectPosition: '35% center',
      },
    ],
    mobileImages: [
      {
        ...enterpriseMobile1,
        alt: 'Équipe projet réunie autour d’un ordinateur.',
        objectPosition: '50% center',
      },
      {
        ...enterpriseMobile2,
        alt: 'Professionnels étudiant ensemble les besoins d’une mission.',
        objectPosition: '50% center',
      },
    ],
  },
].reverse();
---

<PageLayout
  seo={{
    title: 'The Porters — Portage salarial pour consultants IT et tech',
    description: 'The Porters accompagne les consultants IT indépendants en portage salarial : cyber, data, IA, DevOps, cloud, agilité et projet. Simulez vos revenus.',
    structuredData: {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'The Porters',
      url: 'https://www.porters.fr',
      description: 'Société de portage salarial pour consultants IT, tech, conseil et entreprises en France.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://www.porters.fr/blog?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    },
  }}
  noBreadcrumbs={true}
>
  <!-- ==========================================
       HERO SECTION
       ========================================== -->
  <HomeHeroCarousel client:load audiences={heroAudiences}>
    <GoogleReviewsBadge variant="dark" />
  </HomeHeroCarousel>

  <!-- ==========================================
       LOGO MARQUEE — Clients & Partners
       ========================================== -->
  <section class="partner-proof-section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="partner-proof-intro reveal reveal-up">
        <div>
          <p class="partner-proof-kicker">Collaborations & écosystème</p>
          <h2>Des équipes qui nous font déjà <span class="gold-underline">confiance</span></h2>
        </div>
        <p>Grands comptes et partenaires ESN mobilisent The Porters pour des missions IT, data, cyber, cloud et transformation.</p>
      </div>
    </div>
    <div class="partner-proof-marquees reveal reveal-scale">
      <LogoMarquee
        title="Entreprises accompagnées"
        logos={row1}
        direction="left"
        speed="34s"
      />
      <LogoMarquee
        title="Partenaires ESN"
        logos={row2}
        direction="right"
        speed="38s"
      />
    </div>
  </section>

  <!-- ==========================================
       TESTIMONIALS
       ========================================== -->
  <section class="testimonial-feature-section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="testimonial-feature-grid">
        <div class="testimonial-feature-intro reveal reveal-left">
          <p class="testimonial-feature-kicker">L’accompagnement dans la durée</p>
          <div class="testimonial-experience">
            <strong>+10 ans</strong>
            <span>d’expérience aux côtés des consultants indépendants</span>
          </div>
          <h2>Un suivi humain qui reste présent <span class="gold-underline">pendant la mission</span></h2>
          <p>Un interlocuteur unique, une équipe disponible et des réponses concrètes sur le contrat, la paie, les frais et la relation client.</p>

          <div class="testimonial-portrait-group" aria-label="Profils de consultants accompagnés">
            <div class="testimonial-portraits">
              {testimonialPortraits.map((portrait) => (
                <img
                  src={portrait.image.src}
                  width={portrait.image.width}
                  height={portrait.image.height}
                  alt={portrait.alt}
                  style={`object-position: ${portrait.objectPosition}`}
                  loading="lazy"
                />
              ))}
            </div>
            <span>Profils IT, produit, data et transformation</span>
          </div>
        </div>

        <article class="testimonial-feature-quote reveal reveal-right">
          <span class="testimonial-quote-mark" aria-hidden="true">“</span>
          <blockquote>« {testimonials[0].quote} »</blockquote>
          <footer>
            <strong>{testimonials[0].name}</strong>
            <span>{testimonials[0].role}{testimonials[0].city ? ` — ${testimonials[0].city}` : ''}</span>
          </footer>
        </article>
      </div>

      <div class="testimonial-secondary-grid">
        {testimonials.slice(1, 3).map((testimonial, index) => (
          <article class="testimonial-secondary-quote reveal reveal-up" style={`--reveal-delay: ${(index + 1) * 110}ms`}>
            <blockquote>« {testimonial.quote} »</blockquote>
            <footer>
              <strong>{testimonial.name}</strong>
              <span>{testimonial.role}{testimonial.city ? ` — ${testimonial.city}` : ''}</span>
            </footer>
          </article>
        ))}
      </div>

      <p class="testimonial-source-note">Témoignages issus du site The Porters. Les visuels illustrent les profils accompagnés et ne prétendent pas représenter les personnes citées.</p>
    </div>
  </section>

  <!-- ==========================================
       EXPERIENCE PATHWAYS
       ========================================== -->
  <section class="section pt-14 lg:pt-16 bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-10 lg:mb-14 reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Explorer The Porters</p>
        <h2 class="mb-4">Une plateforme de services pour avancer <span class="gold-underline">plus clairement</span></h2>
        <p class="text-porters-black/60 max-w-3xl mx-auto">
          Consultants, entreprises et équipes locales accèdent rapidement au bon parcours : comprendre, simuler, cadrer une mission ou parler à un conseiller.
        </p>
      </div>

      <div class="experience-grid reveal">
        <a href="/portage-salarial" class="experience-card group">
          <img
            src={pathwayConsultantImage.src}
            width={pathwayConsultantImage.width}
            height={pathwayConsultantImage.height}
            alt="Consultante indépendante organisant sa mission depuis son espace de travail."
            class="experience-card-image experience-card-image-consultant"
            loading="lazy"
            decoding="async"
          />
          <span class="experience-card-overlay"></span>
          <span class="experience-card-content">
            <span class="experience-card-kicker">Consultants IT</span>
            <span class="experience-card-title">Exercer librement avec un cadre salarié</span>
            <span class="experience-card-text">
              Cybersécurité, data, IA, cloud, DevOps, Product Ownership ou chefferie de projet : gardez votre autonomie, The Porters prend le relais administratif.
            </span>
            <span class="experience-card-action">
              Découvrir le portage
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </span>
        </a>

        <a href="/entreprises" class="experience-card group">
          <img
            src={pathwayEnterpriseImage.src}
            width={pathwayEnterpriseImage.width}
            height={pathwayEnterpriseImage.height}
            alt="Rendez-vous professionnel conclu par une poignée de main."
            class="experience-card-image experience-card-image-enterprise"
            loading="lazy"
            decoding="async"
          />
          <span class="experience-card-overlay"></span>
          <span class="experience-card-content">
            <span class="experience-card-kicker">Entreprises</span>
            <span class="experience-card-title">Collaborer avec des experts sans complexité</span>
            <span class="experience-card-text">
              Sécurisez une collaboration avec un consultant externe sur un projet IT, data, cloud, cyber ou transformation.
            </span>
            <span class="experience-card-action">
              Solutions entreprises
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </span>
        </a>

        <a href="/simulateur" class="experience-card group">
          <img
            src={pathwaySimulationImage.src}
            width={pathwaySimulationImage.width}
            height={pathwaySimulationImage.height}
            alt="Consultants examinant ensemble des données financières et de mission."
            class="experience-card-image experience-card-image-simulation"
            loading="lazy"
            decoding="async"
          />
          <span class="experience-card-overlay"></span>
          <span class="experience-card-content">
            <span class="experience-card-kicker">Simulation</span>
            <span class="experience-card-title">Estimer son salaire avant d’avancer</span>
            <span class="experience-card-text">
              Comprenez rapidement l’impact de votre TJM, de vos jours facturés et de vos frais professionnels.
            </span>
            <span class="experience-card-action">
              Simuler mes revenus
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </span>
        </a>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3 reveal">
        <div class="service-proof">
          <span>01</span>
          <p>Contrats, facturation et suivi administratif cadrés avec l’entreprise cliente.</p>
        </div>
        <div class="service-proof">
          <span>02</span>
          <p>Lecture claire du TJM, des frais professionnels et des éléments de paie à valider.</p>
        </div>
        <div class="service-proof">
          <span>03</span>
          <p>Accompagnement humain pour positionnement, transition freelance et relation client.</p>
        </div>
      </div>

    </div>
  </section>

  <section class="section bg-porters-navy text-porters-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.42fr_0.58fr] lg:items-start">
        <div class="reveal">
          <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Offres & statuts</p>
          <h2 class="text-porters-white mb-5">Un discours clair pour consultants et entreprises</h2>
          <p class="text-porters-white/68 leading-relaxed">
            La navigation et le contenu séparent maintenant les besoins côté collaborateur et côté client, avec des entrées lisibles par statut, expertise et niveau d'accompagnement.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 reveal">
          {statusCards.map((status) => (
            <article class="status-card">
              <h3>{status.title}</h3>
              <p>{status.body}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="expertise-band reveal">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-porters-gold">Domaines d'expertise</p>
          <h3 class="text-porters-white">Des expertises organisées en sous-catégories</h3>
        </div>
        <div class="expertise-tags">
          {expertiseGroups.map((expertise) => (
            <span>{expertise}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       3-STEP PROCESS
       ========================================== -->
  <section class="section bg-porters-navy/[0.02]">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">L'atelier du Portage Salarial</p>
        <h2 class="mb-4">Du chiffre d'affaires au <span class="gold-underline">salaire</span></h2>
        <p class="text-porters-black/60 max-w-2xl mx-auto">Simplicité, souplesse, service et sécurité pour transformer votre mission en salaire.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center reveal">
          <div class="w-16 h-16 rounded-full border-2 border-porters-gold flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-heading font-bold text-porters-navy">1</span>
          </div>
          <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3">Optimisez vos revenus</h3>
          <p class="text-sm text-porters-black/60 leading-relaxed">
            Vous négociez votre mission et votre TJM avec le client. The Porters met ensuite en place le cadre légal et contractuel.
          </p>
        </div>

        <div class="text-center reveal">
          <div class="w-16 h-16 rounded-full border-2 border-porters-gold flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-heading font-bold text-porters-navy">2</span>
          </div>
          <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3">Libérez-vous de l'administratif</h3>
          <p class="text-sm text-porters-black/60 leading-relaxed">
            Facturation, relation administrative, frais professionnels et suivi de paie sont traités pour vous laisser avancer sur la mission.
          </p>
        </div>

        <div class="text-center reveal">
          <div class="w-16 h-16 rounded-full border-2 border-porters-gold flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-heading font-bold text-porters-navy">3</span>
          </div>
          <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3">Conservez le statut salarié</h3>
          <p class="text-sm text-porters-black/60 leading-relaxed">
            Votre chiffre d'affaires devient un salaire avec bulletin de paie, protection sociale et avantages liés au salariat.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       BENEFITS
       ========================================== -->
  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h2 class="mb-4">Pourquoi choisir <span class="gold-underline">The Porters</span></h2>
        <p class="text-porters-black/60 max-w-2xl mx-auto">Un accompagnement premium, transparent et humain pour vous permettre de vous concentrer sur l'essentiel : votre métier.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Protection complète</h4>
          <p class="text-sm text-porters-black/60">Sécurité sociale, mutuelle, prévoyance et cotisations retraite. Vous êtes protégé comme un salarié classique.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Transparence des frais</h4>
          <p class="text-sm text-porters-black/60">Le taux de gestion de 10 % est affiché dans le simulateur avec le détail des frais, des charges et du net estimé.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Accompagnement humain</h4>
          <p class="text-sm text-porters-black/60">Un chargé de compte dédié vous accompagne au quotidien. Conseils, suivi administratif et support personnalisé.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Paie et avance de trésorerie</h4>
          <p class="text-sm text-porters-black/60">Salaire et frais validés versés dans les cinq premiers jours ouvrés, avec avance de trésorerie selon les conditions contractuelles.</p>
        </div>

        <div class="card p-6 reveal">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Proximité locale</h4>
          <p class="text-sm text-porters-black/60">Paris, Lyon, Aix-en-Provence et Montpellier : quatre implantations mises en avant, avec un suivi à distance partout en France.</p>
        </div>

        <a href="/rse" class="card p-6 reveal block">
          <div class="w-10 h-10 rounded bg-porters-gold/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-porters-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>
          </div>
          <h4 class="font-heading font-semibold text-porters-navy mb-2">Démarche RSE</h4>
          <p class="text-sm text-porters-black/60">Sobriété numérique, inclusion, proximité et transparence structurent une feuille de route suivie et vérifiable.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ==========================================
       SIMULATOR PREVIEW
       ========================================== -->
  <section class="section bg-porters-navy/[0.02]">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <p class="text-sm font-semibold uppercase tracking-wider text-porters-gold mb-4">Simulateur</p>
          <h2 class="mb-6">Estimez vos <span class="gold-underline">revenus</span> en portage salarial</h2>
          <p class="text-porters-black/60 mb-6 leading-relaxed">
            Notre simulateur vous permet d'estimer votre salaire net en fonction de votre taux journalier et de votre volume d'activité. Transparent, simple et immédiat.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3 text-sm text-porters-black/70">
              <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
              Estimation en temps réel
            </li>
            <li class="flex items-start gap-3 text-sm text-porters-black/70">
              <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
              Taux de gestion de 10 % affiché
            </li>
            <li class="flex items-start gap-3 text-sm text-porters-black/70">
              <span class="w-1.5 h-1.5 rounded-full bg-porters-gold mt-2 shrink-0"></span>
              Sans engagement
            </li>
          </ul>
          <a href="/simulateur" class="btn btn-primary">
            Accéder au simulateur
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="reveal">
          <div class="overflow-hidden rounded-lg border border-porters-navy/8 bg-white shadow-[0_18px_50px_rgba(25,43,99,0.06)]">
            <img
              src={simulatorPreviewImage.src}
              width={simulatorPreviewImage.width}
              height={simulatorPreviewImage.height}
              alt="Calcul de revenus sur des documents financiers."
              class="h-56 w-full object-cover"
            />
            <div class="p-8 lg:p-10">
            <div class="space-y-6">
              <div>
                <p class="text-xs uppercase tracking-wider text-porters-black/40 mb-1">Taux journalier moyen</p>
                <p class="text-3xl font-heading font-bold text-porters-navy">500 €<span class="text-base font-normal text-porters-black/40"> / jour</span></p>
              </div>
              <div class="h-px bg-porters-navy/8"></div>
              <div>
                <p class="text-xs uppercase tracking-wider text-porters-black/40 mb-1">Jours travaillés par mois</p>
                <p class="text-3xl font-heading font-bold text-porters-navy">18 <span class="text-base font-normal text-porters-black/40">jours</span></p>
              </div>
              <div class="h-px bg-porters-navy/8"></div>
              <div>
                <p class="text-xs uppercase tracking-wider text-porters-black/40 mb-1">Frais professionnels réels</p>
                <p class="text-3xl font-heading font-bold text-porters-navy">500 €<span class="text-base font-normal text-porters-black/40"> / mois</span></p>
              </div>
              <div class="h-px bg-porters-navy/8"></div>
              <div class="bg-porters-navy/[0.03] rounded p-4">
                <p class="text-xs uppercase tracking-wider text-porters-black/40 mb-1">Salaire net estimé</p>
                <p class="text-3xl font-heading font-bold text-porters-navy">
                  ≈ 4 180 €<span class="text-base font-normal text-porters-black/40"> / mois</span>
                </p>
                <p class="text-xs text-porters-black/40 mt-2">Estimation indicative avant optimisation</p>
              </div>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==========================================
       APPOINTMENT CTA BAND
       ========================================== -->
  <section class="bg-porters-navy py-16 lg:py-20">
    <div class="container mx-auto px-6 lg:px-8 text-center reveal">
      <div class="w-12 h-[3px] bg-porters-gold mx-auto mb-8"></div>
      <h2 class="text-porters-white mb-4">Échangeons sur votre projet</h2>
      <p class="text-porters-white/60 max-w-xl mx-auto mb-8 leading-relaxed">
        Un premier échange gratuit et sans engagement avec l'un de nos conseillers pour répondre à toutes vos questions sur le portage salarial.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/rendez-vous" class="btn btn-gold">
          Parler à un conseiller
        </a>
        <a href="/contact" class="btn btn-white">
          Nous contacter
        </a>
      </div>
    </div>
  </section>

  <!-- ==========================================
       AGENCIES PREVIEW
       ========================================== -->
  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h2 class="mb-4">Nos <span class="gold-underline">agences</span></h2>
        <p class="text-porters-black/60 max-w-2xl mx-auto">Paris, Lyon, Aix-en-Provence et Montpellier : un interlocuteur pour accompagner votre activité, sur place ou à distance.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
        {homepageAgencies.map((agency) => (
          <a href={`/agences/${agency.slug}`} class="card p-6 group reveal block">
            <p class="text-xs font-semibold uppercase tracking-wider text-porters-gold mb-2">{agency.region}</p>
            <h3 class="text-xl font-heading font-semibold text-porters-navy mb-3 group-hover:text-porters-gold transition-colors">{agency.city}</h3>
            <p class="text-sm text-porters-black/60 mb-4 line-clamp-3">{agency.heroSubtitle}</p>
            <span class="text-sm font-medium text-porters-navy group-hover:text-porters-gold transition-colors inline-flex items-center gap-1">
              Découvrir
              <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a href="/agences" class="btn btn-secondary">
          Toutes nos agences
        </a>
      </div>
    </div>
  </section>


  <!-- ==========================================
       RESOURCES PREVIEW
       ========================================== -->
  <section class="section">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-12 reveal">
        <div>
          <h2 class="mb-2">Nos <span class="gold-underline">ressources</span></h2>
          <p class="text-porters-black/60">Articles, guides et livres blancs pour vous accompagner.</p>
        </div>
        <a href="/blog" class="btn btn-ghost mt-4 md:mt-0">
          Voir le blog
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {homepagePosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="card p-0 overflow-hidden group reveal block">
            <div class="h-2 bg-porters-gold"></div>
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-porters-gold mb-3">{getBlogCategory(post.category)?.label || post.category}</p>
              <h3 class="text-lg font-heading font-semibold text-porters-navy mb-3 group-hover:text-porters-gold transition-colors leading-snug">
                {post.title}
              </h3>
              <p class="text-sm text-porters-black/60 line-clamp-3">
                {post.excerpt}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==========================================
       FINAL CTA
       ========================================== -->
  <section class="bg-porters-navy py-20 lg:py-24">
    <div class="container mx-auto px-6 lg:px-8 text-center reveal">
      <div class="w-16 h-[3px] bg-porters-gold mx-auto mb-8"></div>
      <h2 class="text-porters-white mb-4 max-w-2xl mx-auto">
        Prêt à entreprendre<br />en toute sérénité ?
      </h2>
      <p class="text-porters-white/60 max-w-xl mx-auto mb-10 leading-relaxed">
        Rejoignez The Porters et bénéficiez d'un accompagnement premium pour votre activité de consultant indépendant.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/simulateur" class="btn btn-gold">
          Simuler mes revenus
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/rendez-vous" class="btn btn-white">
          Parler à un conseiller
        </a>
      </div>
    </div>
  </section>
</PageLayout>
