---
import PageLayout from '../layouts/PageLayout.astro';
import SiteIcon from '../components/ui/SiteIcon.astro';
import { pageSeo } from '../data/seo.data';
import { aboutPage } from '../content/pages/about';
import { expertiseSections } from '../data/expertise-sections.data';
const history = [
  { marker: '2017', title: 'Les racines de l’écosystème', text: 'L’aventure à l’origine du groupe démarre autour de THE BIG PORTERS, avec une ambition : rapprocher les entreprises de talents qualifiés sur leurs projets numériques.' },
  { marker: 'Ensuite', title: 'Deux métiers complémentaires', text: 'L’écosystème se structure autour de deux réponses distinctes : l’expertise ESN portée par KwickStart et le portage salarial proposé par The Porters.' },
  { marker: 'Aujourd’hui', title: 'Un cadre pensé pour les experts IT', text: 'The Porters accompagne des consultants et des entreprises sur des missions cyber, data, IA, cloud, DevOps, produit, projet et transformation.' },
  { marker: 'La suite', title: 'Rester humain à mesure que le réseau grandit', text: 'La priorité reste la même : une information lisible, un interlocuteur identifiable et un accompagnement adapté à la réalité de chaque mission.' },
];
---

<PageLayout seo={pageSeo.quiSommesNous} breadcrumbs={[{ label: 'Qui sommes-nous' }]}>
  <section class="about-hero">
    <div class="about-shell reveal">
      <p class="eyebrow">The Porters · Notre rôle</p>
      <h1>Le portage salarial pensé pour les experts du numérique.</h1>
      <p>Nous donnons aux consultants l’autonomie pour développer leur activité, avec un cadre salarié clair et un accompagnement qui reste humain.</p>
    </div>
  </section>

  <section class="about-section mission-section" id="mission">
    <div class="about-shell">
      <header class="section-head reveal"><p>Mission & vision</p><h2>Faire du portage un cadre qui soutient l’expertise.</h2></header>
      <div class="mission-system reveal" data-motion-scene>
        <div class="mission-visual">
          <svg class="mission-rings" viewBox="0 0 760 760" aria-hidden="true">
            <circle cx="380" cy="380" r="148" />
            <circle cx="380" cy="380" r="238" />
            <circle cx="380" cy="380" r="316" />
            <path d="M380 64V696M64 380H696M156 156 604 604M604 156 156 604" />
          </svg>
          <div class="vision"><span class="vision-orbit one"></span><span class="vision-orbit two"></span><small>Notre vision</small><strong>Libre dans la mission.<br />Accompagné dans le cadre.</strong><p>Le consultant reste maître de son expertise. The Porters structure le cadre contractuel et administratif.</p></div>
          <div class="mission-orbit">
            {aboutPage.missionCards.map((card, index) => (
              <div class={`mission-orbit-item m${index + 1}`}>
                <article class="mission-card" tabindex="0"><span>0{index + 1}</span><div><h3>{card.title}</h3><p>{card.text}</p></div></article>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section expertise-section" id="expertises">
    <div class="about-shell">
      <header class="section-head light reveal"><p>Nos expertises</p><h2>Un réseau de métiers numériques,<br />un même cadre de mission.</h2></header>
      <div class="expertise-lab reveal" data-expertise-lab>
        {expertiseSections.map((expertise, index) => (
          <div class:list={['expertise-entry', { 'is-active': index === 0 }]} data-expertise-entry>
            <button
              type="button"
              class="expertise-node"
              id={`expertise-tab-${expertise.id}`}
              role="tab"
              aria-selected={index === 0}
              aria-expanded={index === 0}
              aria-controls={`expertise-panel-${expertise.id}`}
              data-expertise-index={index}
              style={`--selector-offset: ${index * 6.1}rem`}
            >
              <span class="expertise-node-copy">
                <i>{expertise.number}</i>
                <span><strong>{expertise.title}</strong><small>{expertise.shortSubtitle}</small></span>
              </span>
              <b class="expertise-node-arrow" aria-hidden="true">↗</b>
            </button>

            <article
              id={`expertise-panel-${expertise.id}`}
              class="expertise-detail expertise-panel"
              role="tabpanel"
              aria-labelledby={`expertise-tab-${expertise.id}`}
              data-expertise-panel
              hidden={index !== 0}
            >
              <header class="expertise-panel-header">
                <p>Domaine sélectionné</p>
                <span class="detail-index">{expertise.number}</span>
                <h3>{expertise.title}</h3>
                <div class="detail-line"></div>
                <div class="expertise-intro-grid">
                  <p class="expertise-introduction">{expertise.introduction}</p>
                  <div class="expertise-description">{expertise.description.map((paragraph) => <p>{paragraph}</p>)}</div>
                </div>
              </header>

              <section class="expertise-panel-section">
                <div class="expertise-section-title"><SiteIcon name="users" /><h4>Profils accompagnés</h4></div>
                <div class="expertise-tags">{expertise.profiles.map((profile) => <span>{profile}</span>)}</div>
              </section>

              <div class="expertise-panel-columns">
                <section class="expertise-panel-section">
                  <div class="expertise-section-title"><SiteIcon name="compass" /><h4>Missions les plus fréquentes</h4></div>
                  <ol class="expertise-mission-list">
                    {expertise.missions.map((mission, missionIndex) => <li><span>{String(missionIndex + 1).padStart(2, '0')}</span><div><strong>{mission.title}</strong><p>{mission.description}</p></div></li>)}
                  </ol>
                </section>
                <section class="expertise-panel-section">
                  <div class="expertise-section-title"><SiteIcon name="clipboard" /><h4>Responsabilités et livrables</h4></div>
                  <ul class="expertise-check-list">{expertise.responsibilities.map((item) => <li><SiteIcon name="check" /><span>{item}</span></li>)}</ul>
                </section>
              </div>

              <section class="expertise-panel-section">
                <div class="expertise-section-title"><SiteIcon name="spark" /><h4>Compétences et environnements</h4></div>
                <div class="expertise-tags expertise-tags--skills">{expertise.skills.map((skill) => <span>{skill}</span>)}</div>
              </section>

              <div class="expertise-panel-columns expertise-panel-columns--compact">
                <section class="expertise-panel-section">
                  <div class="expertise-section-title"><SiteIcon name="building" /><h4>Secteurs concernés</h4></div>
                  <div class="expertise-tags">{expertise.sectors.map((sector) => <span>{sector}</span>)}</div>
                </section>
                <section class="expertise-panel-section expertise-why">
                  <div class="expertise-section-title"><SiteIcon name="scale" /><h4>Pourquoi le portage pour ce profil ?</h4></div>
                  <p>{expertise.whyPortage}</p>
                </section>
              </div>

              <section class="expertise-support">
                <div class="expertise-section-title"><SiteIcon name="shield" /><h4>L’accompagnement Porters</h4></div>
                <ul class="expertise-support-list">{expertise.portersSupport.map((item) => <li><SiteIcon name="check" /><span>{item}</span></li>)}</ul>
              </section>

              <a class="expertise-cta" href={expertise.ctaHref} aria-label={expertise.ctaLabel}>
                <span>{expertise.ctaLabel}</span><b aria-hidden="true">↗</b>
              </a>
            </article>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-section values-section">
    <div class="about-shell values-grid">
      <div class="section-head reveal"><p>Nos valeurs</p><h2>Des principes visibles dans la façon de travailler.</h2></div>
      <div class="values-list reveal">{aboutPage.values.map((value, index) => <details open={index === 0}><summary><span>0{index + 1}</span>{value.title}<b>+</b></summary><p>{value.text}</p></details>)}</div>
    </div>
  </section>

  <section class="about-section history-section" id="histoire">
    <div class="about-shell">
      <header class="section-head reveal"><p>Notre histoire</p><h2>Une histoire de spécialisation,<br />de proximité et de complémentarité.</h2></header>
      <div class="history-timeline" data-history-schema>
        {history.map((item, index) => (
          <div
            class:list={['history-node', `history-node--${index % 2 === 0 ? 'left' : 'right'}`, 'reveal', { 'is-active': index === 0 }]}
            data-history-step
            data-marker={item.marker}
            data-title={item.title}
            style={`--step:${index}; --reveal-delay: ${index * 120}ms`}
          >
            <div class="history-dot-wrap">
              <span class="history-dot">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <article class="history-card">
              <div class="history-card-accent" aria-hidden="true"></div>
              <div class="history-card-inner">
                <span class="history-card-marker">{item.marker}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-cta"><div class="about-shell"><div><p>Votre projet</p><h2>Votre expertise mérite un cadre à sa hauteur.</h2></div><a href="/rendez-vous">Parler à un conseiller →</a></div></section>
</PageLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-expertise-lab]').forEach((lab) => {
    const entries = Array.from(lab.querySelectorAll<HTMLElement>('[data-expertise-entry]'));
    const tabs = entries.map((entry) => entry.querySelector<HTMLButtonElement>('[role="tab"]')).filter((tab): tab is HTMLButtonElement => Boolean(tab));
    const panels = entries.map((entry) => entry.querySelector<HTMLElement>('[data-expertise-panel]')).filter((panel): panel is HTMLElement => Boolean(panel));
    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const select = (position: number, options: { focus?: boolean; updateHash?: boolean } = {}) => {
      const nextPosition = (position + tabs.length) % tabs.length;
      tabs.forEach((tab, index) => {
        const selected = index === nextPosition;
        tab.setAttribute('aria-selected', String(selected));
        tab.setAttribute('aria-expanded', String(selected));
        tab.closest<HTMLElement>('[data-expertise-entry]')?.classList.toggle('is-active', selected);
      });
      panels.forEach((panel, index) => {
        const selected = index === nextPosition;
        panel.hidden = !selected;
        panel.classList.toggle('detail-pop', selected && !reducedMotion);
      });
      if (options.focus) tabs[nextPosition]?.focus();
      if (options.updateHash) history.replaceState(null, '', `#expertise-${tabs[nextPosition]?.id.replace('expertise-tab-', '')}`);
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => select(index, { updateHash: true }));
      tab.addEventListener('keydown', (event) => {
        const key = (event as KeyboardEvent).key;
        if (!['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft', 'Home', 'End'].includes(key)) return;
        event.preventDefault();
        const next = key === 'Home' ? 0 : key === 'End' ? tabs.length - 1 : index + (key === 'ArrowUp' || key === 'ArrowLeft' ? -1 : 1);
        select(next, { focus: true, updateHash: true });
      });
    });

    const hash = window.location.hash.replace('#expertise-', '');
    const hashIndex = tabs.findIndex((tab) => tab.id === `expertise-tab-${hash}`);
    if (hashIndex >= 0) select(hashIndex);
  });
  document.querySelectorAll<HTMLDetailsElement>('.values-list details').forEach((detail) => {
    const summary = detail.querySelector('summary');
    detail.addEventListener('toggle', () => {
      summary?.setAttribute('aria-expanded', String(detail.open));
    });
  });
  document.querySelectorAll<HTMLElement>('[data-history-schema]').forEach((schema) => {
    const steps = Array.from(schema.querySelectorAll<HTMLElement>('[data-history-step]'));

    const setActive = (step: HTMLElement) => {
      steps.forEach((item) => item.classList.toggle('is-active', item === step));
    };

    steps.forEach((step) => {
      step.addEventListener('pointerenter', (event) => {
        if (event.pointerType === 'mouse') setActive(step);
      });
      step.addEventListener('focusin', () => setActive(step));
    });

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const index = steps.indexOf(entry.target as HTMLElement);
          if (index >= 0) setActive(entry.target as HTMLElement);
        });
      }, { rootMargin: '-25% 0px -55% 0px', threshold: 0.2 });
      steps.forEach((step) => observer.observe(step));
    }

    const updateDrawProgress = () => {
      const vh = window.innerHeight;
      steps.forEach((step) => {
        const rect = step.getBoundingClientRect();
        const start = vh * 0.85;
        const end = vh * 0.35;
        let progress = (start - rect.top) / (start - end);
        progress = Math.max(0, Math.min(1, progress));
        step.style.setProperty('--draw', progress.toString());
      });
    };
    window.addEventListener('scroll', updateDrawProgress, { passive: true });
    updateDrawProgress();
  });
  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>('[data-motion-scene]').forEach((scene) => {
      scene.addEventListener('pointermove', (event) => {
        const rect = scene.getBoundingClientRect();
        scene.style.setProperty('--mx', `${((event.clientX - rect.left) / rect.width - .5) * 10}px`);
        scene.style.setProperty('--my', `${((event.clientY - rect.top) / rect.height - .5) * 10}px`);
      });
      scene.addEventListener('pointerleave', () => { scene.style.setProperty('--mx', '0px'); scene.style.setProperty('--my', '0px'); });
    });
  }
</script>

<style>
  .about-shell{width:min(100% - 3rem,82rem);margin:auto}.about-hero{padding:clamp(5rem,10vw,9rem) 0;background:#f4f6f7;text-align:center}.eyebrow,.section-head>p,.about-cta p{margin-bottom:1rem;color:#b79245;font-size:.72rem;font-weight:750;letter-spacing:.15em;text-transform:uppercase}.about-hero h1{max-width:18ch;margin:auto;color:#203440;font-size:clamp(3rem,6vw,6rem);line-height:.98;letter-spacing:-.055em}.about-hero .about-shell>p:last-child{max-width:48rem;margin:1.6rem auto 0;color:rgba(32,52,64,.62);font-size:clamp(1rem,1.5vw,1.2rem);line-height:1.7}.about-section{padding:clamp(5rem,10vw,9rem) 0}.section-head{max-width:52rem;margin-bottom:4rem}.section-head h2{font-size:clamp(2.3rem,4.5vw,4.5rem);line-height:1.03;letter-spacing:-.045em}.section-head.light h2{color:#fff}
  .mission-system {
    --mx: 0px;
    --my: 0px;
    position: relative;
    min-height: clamp(43rem, 58vw, 50rem);
    border: 1px solid rgba(32, 52, 64, 0.1);
    border-radius: 1.5rem;
    background: radial-gradient(circle at 50% 54%, rgba(198, 164, 90, 0.08), transparent 36%), linear-gradient(135deg, #fff, rgba(247, 244, 237, 0.7));
    overflow: hidden;
  }

  .mission-visual {
    position: absolute;
    inset: clamp(1.4rem, 2.4vw, 2.2rem);
    transform: translate(var(--mx), var(--my));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .mission-rings {
    position: absolute;
    inset: 50% auto auto 50%;
    width: min(100%, 42rem);
    height: min(100%, 42rem);
    overflow: visible;
    transform: translate(-50%, -50%);
  }

  .mission-rings circle, .mission-rings path {
    fill: none;
    stroke: rgba(32, 52, 64, 0.14);
    stroke-width: 1;
    stroke-dasharray: 7 10;
    transform-origin: center;
    animation: orbit 42s linear infinite;
  }

  .mission-rings circle:nth-child(2) {
    stroke: rgba(198, 164, 90, 0.24);
    animation-direction: reverse;
    animation-duration: 54s;
  }

  .mission-rings circle:nth-child(3) {
    stroke: rgba(32, 52, 64, 0.08);
    animation-duration: 68s;
  }

  .mission-rings path { stroke: rgba(32, 52, 64, 0.08); animation: none; }

  .mission-orbit {
    position: absolute;
    inset: 0;
    z-index: 3;
    animation: mission-spin 54s linear infinite;
  }

  .mission-system:hover .mission-orbit, .mission-system:focus-within .mission-orbit,
  .mission-system:hover .mission-card, .mission-system:focus-within .mission-card,
  .mission-system:hover .mission-rings circle, .mission-system:focus-within .mission-rings circle {
    animation-play-state: paused;
  }

  .mission-orbit-item {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(12.5rem, 17vw, 15.5rem);
    transform: rotate(var(--angle)) translate(clamp(13.5rem, 22vw, 17.75rem)) rotate(calc(-1 * var(--angle))) translate(-50%, -50%);
    transform-origin: 0 0;
  }

  .m1 { --angle: -92deg; }
  .m2 { --angle: -28deg; }
  .m3 { --angle: 34deg; }
  .m4 { --angle: 95deg; }
  .m5 { --angle: 158deg; }
  .m6 { --angle: 218deg; }

  .mission-card {
    display: grid;
    grid-template-columns: 2.15rem 1fr;
    gap: 0.75rem;
    min-height: 8.8rem;
    padding: 1rem;
    border: 1px solid rgba(32, 52, 64, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    box-shadow: 0 14px 35px rgba(32, 52, 64, 0.07);
    animation: mission-spin-reverse 54s linear infinite;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.3s ease, box-shadow 0.4s ease;
    cursor: default;
  }

  .mission-card:hover, .mission-card:focus-visible {
    border-color: rgba(198, 164, 90, 0.72);
    background: #fff;
    box-shadow: 0 22px 54px rgba(32, 52, 64, 0.15), 0 0 0 4px rgba(198, 164, 90, 0.1);
    outline: none;
    transform: translateY(-7px) scale(1.025);
    z-index: 10;
  }

  .mission-card > span {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid rgba(198, 164, 90, 0.45);
    border-radius: 50%;
    color: #b79245;
    font: 700 0.6rem var(--font-mono);
    transition: background 0.3s ease, color 0.3s ease;
  }

  .mission-card:hover > span {
    background: #c6a45a;
    color: #fff;
  }

  .mission-card h3 { font-size: 0.9rem; line-height: 1.28; }
  .mission-card p {
    margin: 0.45rem 0 0;
    color: rgba(32, 52, 64, 0.65);
    font-size: 0.68rem;
    line-height: 1.5;
  }

  .vision {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 4;
    display: flex;
    width: clamp(16rem, 24vw, 19rem);
    height: clamp(16rem, 24vw, 19rem);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(198, 164, 90, 0.6);
    border-radius: 50%;
    padding: 2.5rem;
    background: radial-gradient(circle at 50% 18%, rgba(198, 164, 90, 0.12), transparent 42%), #203440;
    color: #fff;
    text-align: center;
    box-shadow: 0 28px 75px rgba(32, 52, 64, 0.24), inset 0 0 40px rgba(0,0,0,0.5);
    transform: translate(calc(-50% + var(--mx) * -.35), calc(-50% + var(--my) * -.35));
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .vision-orbit {
    position: absolute;
    inset: -1.15rem;
    border: 1px dashed rgba(198, 164, 90, 0.32);
    border-radius: 50%;
    animation: orbit 24s linear infinite;
  }

  .vision-orbit.two {
    inset: -2.15rem;
    border-color: rgba(32, 52, 64, 0.16);
    animation-direction: reverse;
    animation-duration: 31s;
  }

  .vision small { color: #c6a45a; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  .vision strong { margin-top: 0.85rem; font-size: 1.25rem; line-height: 1.25; }
  .vision p { margin: 0.85rem 0 0; color: rgba(255, 255, 255, 0.65); font-size: 0.75rem; line-height: 1.5; }
  .expertise-section {
    background: #10202b;
    color: #fff;
    overflow: hidden;
  }

  .expertise-lab {
    position: relative;
    display: block;
    min-height: 58rem;
    padding: clamp(1rem, 1.6vw, 1.4rem);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.018);
  }

  .expertise-entry { display: contents; }

  .expertise-node {
    position: absolute;
    top: calc(clamp(1rem, 1.6vw, 1.4rem) + var(--selector-offset));
    left: clamp(1rem, 1.6vw, 1.4rem);
    display: flex;
    width: calc(36% - clamp(1rem, 1.6vw, 1.4rem));
    min-width: 0;
    min-height: 5.35rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.75rem;
    background: rgba(23, 44, 56, 0.86);
    color: #fff;
    cursor: pointer;
    font: inherit;
    text-align: left;
    transition: border-color 220ms ease, background-color 220ms ease, color 220ms ease;
  }

  .expertise-node:hover {
    border-color: rgba(198, 164, 90, 0.62);
    background: rgba(198, 164, 90, 0.08);
  }

  .expertise-node:focus-visible {
    border-color: #c6a45a;
    outline: 3px solid rgba(198, 164, 90, 0.2);
    outline-offset: 3px;
  }

  .expertise-entry.is-active .expertise-node {
    border-color: #c6a45a;
    background: rgba(198, 164, 90, 0.13);
  }

  .expertise-node-copy {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.8rem;
  }

  .expertise-node-copy > i {
    display: grid;
    width: 2rem;
    height: 2rem;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 50%;
    background: rgba(198, 164, 90, 0.12);
    color: #c6a45a;
    font: 700 0.62rem var(--font-mono);
    font-style: normal;
    transition: background-color 220ms ease, color 220ms ease;
  }

  .expertise-entry.is-active .expertise-node-copy > i { background: #c6a45a; color: #10202b; }

  .expertise-node-copy > span { display: grid; min-width: 0; gap: 0.3rem; }
  .expertise-node strong { font-size: 0.98rem; line-height: 1.2; }
  .expertise-node small { color: rgba(255, 255, 255, 0.5); font-size: 0.7rem; line-height: 1.35; }
  .expertise-entry.is-active .expertise-node small { color: rgba(255, 255, 255, 0.68); }
  .expertise-node-arrow { color: #c6a45a; font-size: 1rem; transition: transform 220ms ease; }
  .expertise-node:hover .expertise-node-arrow, .expertise-node:focus-visible .expertise-node-arrow { transform: translate(3px, -3px); }

  .expertise-panel {
    position: relative;
    width: auto;
    margin-left: calc(36% + 0.75rem);
    min-height: 58rem;
    overflow: hidden;
