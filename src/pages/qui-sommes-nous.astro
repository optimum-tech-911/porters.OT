---
import PageLayout from '../layouts/PageLayout.astro';
import { pageSeo } from '../data/seo.data';
import teamDiscussionImage from '../../images/business-meeting.webp';
import workshopImage from '../../images/team-workshop.webp';
import { aboutPage } from '../content/pages/about';
---

<PageLayout seo={pageSeo.quiSommesNous} breadcrumbs={[{ label: 'Qui sommes-nous' }]}>
  <section class="section bg-porters-navy/[0.03] pt-12 lg:pt-20">
    <div class="container mx-auto px-6 text-center lg:px-8">
      <div class="mx-auto max-w-4xl reveal">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">The Porters</p>
        <h1 class="mb-5">Qui sommes-nous ?</h1>
        <p class="font-heading text-xl font-semibold text-porters-gold sm:text-2xl">Le portage salarial pensé pour les experts du numérique</p>
        <p class="mx-auto mt-5 max-w-3xl text-base leading-relaxed text-porters-black/62 sm:text-lg">
          Notre rôle est simple : donner aux consultants l’autonomie pour développer leur activité, avec un cadre salarié clair et un accompagnement qui reste humain.
        </p>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="mx-auto max-w-5xl reveal">
        <div class="mb-12 text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Notre mission</p>
          <h2>Faire du portage un cadre qui soutient l’expertise</h2>
        </div>
        <div class="mx-auto mb-8 max-w-3xl rounded-2xl bg-porters-navy p-8 text-center text-porters-white lg:p-10">
          <p class="mb-3 font-heading text-xl font-semibold text-porters-white">Notre vision</p>
          <p class="mb-0 leading-relaxed text-porters-white/75">Un consultant doit pouvoir se concentrer sur la valeur qu’il apporte à son client, sans naviguer seul entre contrats, facturation, paie et obligations administratives.</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {aboutPage.missionCards.map((card, index) => (
            <article class="rounded-xl border border-porters-navy/15 bg-white p-6 text-center reveal">
              <span class="mx-auto mb-5 flex h-10 w-10 items-center justify-center rounded-full bg-porters-gold/12 font-mono text-sm font-semibold text-porters-gold">0{index + 1}</span>
              <h3 class="text-lg">{card.title}</h3>
              <p class="mb-0 mt-3 text-sm leading-relaxed text-porters-black/62">{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-porters-navy/[0.03]">
    <div class="container mx-auto grid gap-12 px-6 lg:grid-cols-[minmax(18rem,0.72fr)_minmax(0,1fr)] lg:items-center lg:gap-20 lg:px-8">
      <div class="grid gap-4 reveal">
        <img src={teamDiscussionImage.src} width={teamDiscussionImage.width} height={teamDiscussionImage.height} alt="Échange professionnel autour d’une mission." class="h-64 w-full rounded-xl object-cover" />
        <img src={workshopImage.src} width={workshopImage.width} height={workshopImage.height} alt="Atelier de travail en équipe." class="h-40 w-full rounded-xl object-cover" />
      </div>
      <div class="reveal">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Nos valeurs</p>
        <h2>Des principes visibles dans la manière de travailler</h2>
        <div class="mt-8 divide-y divide-porters-navy/10 border-y border-porters-navy/10">
          {aboutPage.values.map((value, index) => (
            <details class="group py-5" open={index === 0}>
              <summary class="flex cursor-pointer list-none items-center justify-between font-heading font-semibold text-porters-navy">
                {value.title}<span class="text-porters-gold transition-transform group-open:rotate-45">+</span>
              </summary>
              <p class="mb-0 mt-4 max-w-xl text-sm leading-relaxed text-porters-black/62">{value.text}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container mx-auto px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-3xl text-center reveal">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-porters-gold">Notre approche</p>
        <h2>De votre projet au suivi de mission</h2>
      </div>
      <ol class="mx-auto grid max-w-5xl gap-6 md:grid-cols-4">
        {aboutPage.approach.map((step, index) => (
          <li class="border-t-2 border-porters-gold pt-6 reveal">
            <span class="font-mono text-sm font-semibold text-porters-gold">0{index + 1}</span>
            <h3 class="mt-4 text-lg">{step.title}</h3>
            <p class="mb-0 mt-3 text-sm leading-relaxed text-porters-black/62">{step.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="bg-porters-navy py-16 text-porters-white">
    <div class="container mx-auto flex flex-col gap-7 px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <div class="max-w-2xl reveal"><h2 class="mb-2 text-porters-white">Votre expertise mérite un cadre à sa hauteur.</h2><p class="mb-0 text-porters-white/65">Parlons de votre mission, de votre statut et des conditions de démarrage.</p></div>
      <a href="/rendez-vous" class="btn btn-gold shrink-0">Parler à un conseiller</a>
    </div>
  </section>
</PageLayout>
