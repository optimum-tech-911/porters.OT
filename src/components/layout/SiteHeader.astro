---
const navGroups = [
  {
    label: 'Consultants',
    items: [
      { label: 'Le portage salarial', href: '/portage-salarial' },
      { label: 'Simulateur de revenus', href: '/simulateur' },
      { label: 'Parler à un conseiller', href: '/rendez-vous' },
    ],
  },
  {
    label: 'Entreprises',
    href: '/entreprises',
  },
  {
    label: 'The Porters',
    items: [
      { label: 'Qui sommes-nous', href: '/qui-sommes-nous' },
      { label: 'Notre équipe', href: '/equipe' },
      { label: 'Nos agences', href: '/agences' },
      { label: 'Recrutement', href: '/recrutement' },
      { label: 'Parrainage', href: '/parrainage' },
    ],
  },
  {
    label: 'Ressources',
    items: [
      { label: 'Blog', href: '/blog' },
      { label: 'Livres blancs', href: '/livres-blancs' },
      { label: 'FAQ', href: '/faq' },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="container mx-auto relative flex items-center justify-between gap-2 h-20 px-4 sm:px-6 lg:px-8">
    <div class="lg:hidden w-9 h-9 shrink-0" aria-hidden="true"></div>

    <!-- Logo -->
    <a
      href="/"
      class="absolute left-1/2 -translate-x-1/2 flex items-center shrink-0 min-w-0 max-w-[7.4rem] sm:max-w-none lg:static lg:translate-x-0"
      aria-label="The Porters — Accueil"
    >
      <span class="brand-wordmark" aria-hidden="true">
        <span class="brand-wordmark-the">The</span>
        <span class="brand-wordmark-porters">Porters</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
      {navGroups.map((group) => (
        <div class="relative group">
          {group.items ? (
            <>
              <button
                class="px-4 py-2 text-[0.9375rem] font-medium text-porters-black/80 hover:text-porters-navy transition-colors link-hover-gold"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {group.label}
                <svg class="inline-block ml-1 w-3.5 h-3.5 opacity-50 transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white border border-porters-navy/8 rounded-lg shadow-lg py-2 min-w-[220px]">
                  {group.items.map((item) => (
                    <a
                      href={item.href}
                      class:list={[
                        'block px-5 py-2.5 text-sm text-porters-black/70 hover:text-porters-navy hover:bg-porters-navy/3 transition-colors',
                        { 'text-porters-navy font-medium': currentPath === item.href },
                      ]}
                    >
                      {item.label}
                    </a>
                  ))}
                </div>
              </div>
            </>
          ) : (
            <a
              href={group.href}
              class:list={[
                'px-4 py-2 text-[0.9375rem] font-medium text-porters-black/80 hover:text-porters-navy transition-colors link-hover-gold',
                { 'text-porters-navy': currentPath === group.href },
              ]}
            >
              {group.label}
            </a>
          )}
        </div>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a
      href="/simulateur"
      class="hidden lg:inline-flex btn btn-primary text-sm"
    >
      Simuler mes revenus
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden shrink-0 flex items-center justify-center w-9 h-9 text-porters-navy"
      aria-label="Ouvrir le menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <button
    id="mobile-menu-backdrop"
    class="lg:hidden fixed inset-0 top-20 z-30 bg-porters-black/20 opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
    tabindex="-1"
  ></button>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-x-0 top-20 bottom-0 bg-porters-white z-40 transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
  >
    <nav class="px-6 py-8 space-y-6" aria-label="Navigation mobile">
      {navGroups.map((group) => (
        <div class="border-b border-porters-navy/8 pb-6 last:border-0">
          {group.items ? (
            <>
              <p class="text-xs font-semibold uppercase tracking-wider text-porters-gold mb-3">
                {group.label}
              </p>
              <div class="space-y-1">
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'block py-2 text-porters-black/70 hover:text-porters-navy transition-colors',
                      { 'text-porters-navy font-medium': currentPath === item.href },
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={group.href}
              class:list={[
                'block py-2 text-lg font-medium text-porters-navy',
                { 'text-porters-gold': currentPath === group.href },
              ]}
            >
              {group.label}
            </a>
          )}
        </div>
      ))}
      <a href="/simulateur" class="btn btn-primary w-full text-center mt-4">
        Simuler mes revenus
      </a>
      <a href="/contact" class="btn btn-secondary w-full text-center">
        Nous contacter
      </a>
    </nav>
  </div>
</header>

<!-- Header spacer for fixed positioning -->
<div class="h-20"></div>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  const menuLinks = menu?.querySelectorAll('a');
  let isOpen = false;

  const syncMenuState = (nextState) => {
    isOpen = nextState;
    menu?.classList.toggle('translate-x-full', !isOpen);
    menu?.classList.toggle('translate-x-0', isOpen);
    backdrop?.classList.toggle('opacity-0', !isOpen);
    backdrop?.classList.toggle('pointer-events-none', !isOpen);
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  };

  toggle?.addEventListener('click', () => {
    syncMenuState(!isOpen);
  });

  backdrop?.addEventListener('click', () => {
    syncMenuState(false);
  });

  menuLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      syncMenuState(false);
    });
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && isOpen) {
      syncMenuState(false);
    }
  });

  // Header scroll effect
  const header = document.getElementById('site-header');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      header?.classList.add('bg-white', 'shadow-sm', 'border-b', 'border-porters-navy/5');
    } else {
      header?.classList.remove('bg-white', 'shadow-sm', 'border-b', 'border-porters-navy/5');
    }

    lastScroll = currentScroll;
  }, { passive: true });

  // Initial state
  if (window.scrollY > 50) {
    header?.classList.add('bg-white', 'shadow-sm', 'border-b', 'border-porters-navy/5');
  }
</script>
