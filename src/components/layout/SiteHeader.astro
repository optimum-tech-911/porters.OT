---
import { franceMapPins, franceMapRoutes } from '../../data/france-map.data';

type NavLink = {
  label: string;
  href: string;
  note?: string;
};

type NavItem = {
  id: string;
  label: string;
  href: string;
  description: string;
  links: NavLink[];
};

const leftNav: NavItem[] = [
  {
    id: 'portage',
    label: 'Le portage salarial',
    href: '/portage-salarial',
    description: 'Comprendre le cadre, les étapes et les réponses utiles sans alourdir la navigation.',
    links: [
      { label: 'Comprendre le portage salarial', href: '/portage-salarial', note: 'Cadre, contrat, paie' },
      { label: 'Pour consultants indépendants', href: '/consultants', note: 'Parcours consultant' },
      { label: 'FAQ portage salarial', href: '/faq', note: 'Questions clés' },
    ],
  },
  {
    id: 'offers',
    label: 'Nos offres',
    href: '/consultants',
    description: 'Des parcours distincts pour consultants, entreprises et expertises IT.',
    links: [
      { label: 'Consultants', href: '/consultants', note: 'Indépendance cadrée' },
      { label: 'Entreprises', href: '/entreprises', note: 'Renforts experts' },
      { label: 'Expertises IT', href: '/expertises', note: 'Cyber, data, cloud' },
    ],
  },
];

const rightNav: NavItem[] = [
  {
    id: 'group',
    label: 'Le groupe',
    href: '/qui-sommes-nous',
    description: 'Mission, expertises, histoire et points de contact The Porters.',
    links: [
      { label: 'Qui sommes-nous', href: '/qui-sommes-nous', note: 'Notre mission et notre vision' },
      { label: 'Agences', href: '/agences', note: 'Points de contact documentés' },
    ],
  },
  {
    id: 'resources',
    label: 'Ressources',
    href: '/blog',
    description: 'Guides, réponses et contenus pour avancer avec plus de clarté.',
    links: [
      { label: 'Blog', href: '/blog', note: 'Articles et guides' },
      { label: 'FAQ', href: '/faq', note: 'Réponses rapides' },
      { label: 'Livres blancs', href: '/livres-blancs', note: 'Guides pratiques' },
    ],
  },
];

const mobileNav = [...leftNav, ...rightNav];

const currentPath = Astro.url.pathname;
const active = (href: string) => {
  const path = href.split('#')[0];
  return path !== '/' && (currentPath === path || currentPath.startsWith(`${path}/`));
};
---

<header class="tp-site-header" id="site-header">
  <div class="tp-header-glow" aria-hidden="true"></div>
  <div class="tp-header-inner">
    <nav class="tp-desktop-nav tp-desktop-nav--left" aria-label="Navigation principale gauche">
      {leftNav.map((item) => (
        <div class:list={['tp-nav-item', { 'is-active': active(item.href) }]} data-popover>
          <a href={item.href} class="tp-nav-link">{item.label}</a>
          <button
            class="tp-nav-toggle"
            type="button"
            aria-label={`Afficher ${item.label}`}
            aria-controls={`tp-nav-popover-${item.id}`}
            aria-expanded="false"
          >
            <span aria-hidden="true">⌄</span>
          </button>
          <div class="tp-nav-popover" id={`tp-nav-popover-${item.id}`} role="group" aria-label={item.label}>
            <div class="tp-popover-intro">
              <span>{item.label}</span>
              <p>{item.description}</p>
            </div>
            <div class="tp-popover-links">
              {item.links.map((link) => (
                <a href={link.href}>
                  <span>
                    <strong>{link.label}</strong>
                    {link.note && <small>{link.note}</small>}
                  </span>
                  <b aria-hidden="true">↗</b>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
      <a href="/simulateur" class:list={['tp-nav-direct', { 'is-active': active('/simulateur') }]}>Simulateur</a>
    </nav>

    <a href="/" class="tp-header-brand" aria-label="The Porters - Accueil">
      <span class="brand-wordmark brand-wordmark-light" aria-hidden="true">
        <span class="brand-wordmark-the">The</span>
        <span class="brand-wordmark-porters">Porters</span>
      </span>
    </a>

    <nav class="tp-desktop-nav tp-desktop-nav--right" aria-label="Navigation principale droite">
      {rightNav.map((item) => (
        <div class:list={['tp-nav-item', `tp-nav-item--${item.id}`, { 'is-active': active(item.href) }]} data-popover>
          <a href={item.href} class="tp-nav-link">{item.label}</a>
          <button
            class="tp-nav-toggle"
            type="button"
            aria-label={`Afficher ${item.label}`}
            aria-controls={`tp-nav-popover-${item.id}`}
            aria-expanded="false"
          >
            <span aria-hidden="true">⌄</span>
          </button>
          <div class:list={['tp-nav-popover', { 'tp-nav-popover--group': item.id === 'group' }]} id={`tp-nav-popover-${item.id}`} role="group" aria-label={item.label}>
            <div class="tp-popover-intro">
              <span>{item.label}</span>
              <p>{item.description}</p>
            </div>
            <div class="tp-popover-links">
              {item.links.map((link) => (
                <a href={link.href} class:list={[{ 'tp-agences-trigger': link.label === 'Agences' }]} data-agences={link.label === 'Agences' ? 'true' : undefined}>
                  <span>
                    <strong>{link.label}</strong>
                    {link.note && <small>{link.note}</small>}
                  </span>
                  <b aria-hidden="true">↗</b>
                </a>
              ))}
            </div>
            {item.id === 'group' && (
              <div class="tp-france-map-panel" id="tp-france-map" aria-label="Carte des agences The Porters">
                <div class="tp-france-map-inner">
                  <div class="tp-france-map-container">
                    <img src="/images/france-outline-source.svg" alt="Carte de France" loading="lazy" decoding="async" class="tp-france-svg" />
                    <svg class="tp-france-routes" viewBox="0 0 507 520" aria-hidden="true">
                      {franceMapRoutes.map((route) => <path d={route.d} />)}
                    </svg>
                    {franceMapPins.map((pin, index) => (
                      <a
                        href={pin.href}
                        class:list={['tp-map-pin', `label-${pin.labelSide || 'right'}`, { 'is-muted': pin.status, 'is-active': !pin.status }]}
                        style={`--pin-x:${pin.x}%;--pin-y:${pin.y}%;--pin-delay:${index * 95}ms`}
                        title={pin.status ? `${pin.city} — ${pin.status}` : pin.city}
                        aria-label={pin.city}
                      >
                        <span class="tp-map-pin-dot"></span>
                        <span class="tp-map-pin-pulse"></span>
                        <span class="tp-map-pin-label">{pin.city}</span>
                      </a>
                    ))}
                  </div>
                  <div class="tp-france-map-legend">
                    <strong>Nos agences</strong>
                    <small>Paris · Lyon · Montpellier · Aix-Marseille</small>
                    <em>Lille et Bordeaux — bientôt</em>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
      <a href="/contact" class="tp-contact-link" aria-label="Contacter The Porters">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4.5 6.5h15v11h-15z"></path>
          <path d="m5 7 7 6 7-6"></path>
        </svg>
      </a>
      <a href="/rendez-vous" class="tp-appointment-link">Rendez-vous <span aria-hidden="true">→</span></a>
    </nav>

    <button class="tp-menu-toggle" id="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Ouvrir le menu">
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="tp-mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Navigation mobile">
      {mobileNav.map((item, index) => (
        <details class="tp-mobile-group">
          <summary>
            <span>0{index + 1}</span>
            {item.label}
            <b aria-hidden="true">⌄</b>
          </summary>
          <div>
            <a class="tp-mobile-overview" href={item.href}>
              <strong>Vue d’ensemble</strong>
              <small>{item.description}</small>
            </a>
            {item.links.map((link) => (
              <a href={link.href}>
                <span>
                  <strong>{link.label}</strong>
                  {link.note && <small>{link.note}</small>}
                </span>
                <b aria-hidden="true">→</b>
              </a>
            ))}
          </div>
        </details>
      ))}
      <div class="tp-mobile-actions">
        <a href="/simulateur">Simulateur</a>
        <a href="/rendez-vous">Prendre rendez-vous</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>
  </div>
</header>
<div class="tp-header-spacer" aria-hidden="true"></div>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const navItems = document.querySelectorAll<HTMLElement>('.tp-nav-item[data-popover]');
  let lastScrollY = window.scrollY;
  let ticking = false;
  let mobileOpen = false;

  const hasOpenPopover = () => Array.from(navItems).some((item) => item.classList.contains('is-open'));
  const syncHeaderOpenState = () => {
    header?.classList.toggle('tp-site-header--menu-open', mobileOpen || hasOpenPopover() || Boolean(header?.matches(':focus-within')));
  };

  const setMobileOpen = (open: boolean) => {
    mobileOpen = open;
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    menu?.setAttribute('aria-hidden', String(!open));
    header?.classList.toggle('tp-site-header--mobile-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
    syncHeaderOpenState();
  };

  const setPopoverOpen = (item: HTMLElement, open: boolean) => {
    const button = item.querySelector<HTMLButtonElement>('.tp-nav-toggle');
    item.classList.toggle('is-open', open);
    button?.setAttribute('aria-expanded', String(open));
    syncHeaderOpenState();
  };

  const closePopovers = (except?: HTMLElement) => {
    navItems.forEach((item) => {
      if (item !== except) setPopoverOpen(item, false);
    });
  };

  navItems.forEach((item) => {
    const button = item.querySelector<HTMLButtonElement>('.tp-nav-toggle');

    item.addEventListener('pointerenter', (event) => {
      if (event.pointerType === 'mouse') {
        closePopovers(item);
        setPopoverOpen(item, true);
      }
    });

    item.addEventListener('pointerleave', (event) => {
      if (event.pointerType === 'mouse') setPopoverOpen(item, false);
    });

    item.addEventListener('focusin', () => {
      closePopovers(item);
      setPopoverOpen(item, true);
    });

    item.addEventListener('focusout', (event) => {
      if (!item.contains(event.relatedTarget as Node | null)) setPopoverOpen(item, false);
    });

    button?.addEventListener('click', (event) => {
      event.preventDefault();
      const opening = !item.classList.contains('is-open');
      closePopovers(item);
      setPopoverOpen(item, opening);
    });
  });

  toggle?.addEventListener('click', () => setMobileOpen(toggle.getAttribute('aria-expanded') !== 'true'));
  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMobileOpen(false)));

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    closePopovers();
    setMobileOpen(false);
  });

  document.addEventListener('click', (event) => {
    const target = event.target as Node;
    if (!header?.contains(target)) closePopovers();
  });

  const syncScroll = () => {
    const current = window.scrollY;
    const lockedOpen = mobileOpen || hasOpenPopover() || Boolean(header?.matches(':focus-within'));

    header?.classList.toggle('tp-site-header--scrolled', current > 8);

    if (current < 80 || lockedOpen) {
      header?.classList.remove('tp-site-header--hidden');
    } else if (current > lastScrollY + 8 && current > 120) {
      header?.classList.add('tp-site-header--hidden');
    } else if (current < lastScrollY - 8) {
      header?.classList.remove('tp-site-header--hidden');
    }

    lastScrollY = Math.max(current, 0);
    ticking = false;
  };

  syncScroll();
  addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(syncScroll);
      ticking = true;
    }
  }, { passive: true });

  // Interactive France map - show on Agences hover
  const agencesLink = document.querySelector<HTMLElement>('[data-agences]');
  const franceMap = document.getElementById('tp-france-map');

  if (agencesLink && franceMap) {
    agencesLink.addEventListener('pointerenter', (event) => {
      if (event.pointerType === 'mouse') {
        franceMap.classList.add('is-visible');
      }
    });

    agencesLink.addEventListener('pointerleave', (event) => {
      if (event.pointerType === 'mouse') {
        // Check if pointer moved to the map itself
        const related = event.relatedTarget as Node | null;
        if (!franceMap.contains(related)) {
          franceMap.classList.remove('is-visible');
        }
      }
    });

    franceMap.addEventListener('pointerleave', (event) => {
      if (event.pointerType === 'mouse') {
        const related = event.relatedTarget as Node | null;
        if (related !== agencesLink && !agencesLink.contains(related)) {
          franceMap.classList.remove('is-visible');
        }
      }
    });

    franceMap.addEventListener('pointerenter', (event) => {
      if (event.pointerType === 'mouse') {
        franceMap.classList.add('is-visible');
      }
    });
  }
</script>

<style>
  .tp-site-header {
    --tp-header-height: 5.75rem;
    position: fixed;
    inset: 0 0 auto;
    z-index: 80;
    color: #fff;
    background:
      linear-gradient(180deg, rgba(16, 32, 43, 0.96), rgba(16, 32, 43, 0.84)),
      radial-gradient(ellipse at 50% -20%, rgba(190, 158, 88, 0.18), transparent 58%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px) saturate(1.08);
    transition:
      transform 320ms var(--ease-soft),
      background 260ms ease,
      box-shadow 260ms ease,
      border-color 260ms ease;
  }

  .tp-site-header::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(190, 158, 88, 0.74), transparent);
    content: "";
    opacity: 0.5;
    transform: scaleX(0.34);
    transition: opacity 260ms ease, transform 520ms var(--ease-soft);
  }

  .tp-site-header--hidden {
    transform: translateY(calc(-100% - 2px));
  }

  .tp-site-header--scrolled,
  .tp-site-header--menu-open {
    background:
      linear-gradient(180deg, rgba(16, 32, 43, 0.985), rgba(16, 32, 43, 0.94)),
      radial-gradient(ellipse at 50% -18%, rgba(190, 158, 88, 0.2), transparent 60%);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 18px 55px rgba(5, 15, 22, 0.22);
  }

  .tp-site-header--scrolled::after,
  .tp-site-header--menu-open::after {
    opacity: 0.9;
    transform: scaleX(1);
  }

  .tp-header-glow {
    position: absolute;
    inset: 0 18%;
    pointer-events: none;
    background: radial-gradient(ellipse at 50% -24%, rgba(255, 255, 255, 0.08), transparent 56%);
  }

  .tp-header-inner {
    position: relative;
    display: grid;
    width: min(100% - 3rem, 94rem);
    height: var(--tp-header-height);
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(1rem, 2.4vw, 2.4rem);
    margin-inline: auto;
  }

  .tp-desktop-nav {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: clamp(0.75rem, 1.6vw, 1.55rem);
  }

  .tp-desktop-nav--left {
    justify-content: flex-end;
  }

  .tp-desktop-nav--right {
    justify-content: flex-start;
  }

  .tp-header-brand {
    position: relative;
    z-index: 3;
    display: flex;
    width: max-content;
    color: #fff;
  }

  .tp-header-brand .brand-wordmark {
    transform: scale(0.96);
    transform-origin: center;
    transition: transform 320ms var(--ease-soft), filter 220ms ease;
  }

  .tp-header-brand:hover .brand-wordmark,
  .tp-header-brand:focus-visible .brand-wordmark {
    filter: drop-shadow(0 0 15px rgba(190, 158, 88, 0.3));
    transform: scale(1);
  }

  .tp-header-brand :global(.brand-wordmark-the),
  .tp-header-brand :global(.brand-wordmark-porters) {
    color: #fff !important;
  }

  .tp-nav-item {
    position: relative;
    display: flex;
    align-items: center;
    padding-block: 1.85rem;
  }

  .tp-nav-link,
  .tp-nav-direct {
    position: relative;
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(0.98rem, 1.12vw, 1.16rem);
    font-weight: 760;
    line-height: 1;
    white-space: nowrap;
    transition: color 180ms ease;
  }

  .tp-nav-link::after,
  .tp-nav-direct::after {
    position: absolute;
    right: 0;
    bottom: -0.58rem;
    left: 0;
    height: 1px;
    background: #be9e58;
    content: "";
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms var(--ease-soft);
  }

  .tp-nav-direct {
    display: inline-flex;
    align-items: center;
    min-height: 2.9rem;
    padding-inline: 0.55rem;
  }

  .tp-nav-item:hover .tp-nav-link,
  .tp-nav-item:focus-within .tp-nav-link,
  .tp-nav-item.is-active .tp-nav-link,
  .tp-nav-direct:hover,
  .tp-nav-direct:focus-visible,
  .tp-nav-direct.is-active {
    color: #fff;
  }

  .tp-nav-item:hover .tp-nav-link::after,
  .tp-nav-item:focus-within .tp-nav-link::after,
  .tp-nav-item.is-active .tp-nav-link::after,
  .tp-nav-direct:hover::after,
  .tp-nav-direct:focus-visible::after,
  .tp-nav-direct.is-active::after {
    transform: scaleX(1);
  }

  .tp-nav-toggle {
    display: grid;
    width: 1.42rem;
    height: 1.42rem;
    place-items: center;
    border: 0;
    background: none;
    color: rgba(255, 255, 255, 0.52);
    cursor: pointer;
    font: inherit;
    transition: color 180ms ease, transform 240ms var(--ease-soft);
  }

  .tp-nav-toggle span {
    display: block;
    transform: translateY(-1px);
  }

  .tp-nav-item:hover .tp-nav-toggle,
  .tp-nav-item:focus-within .tp-nav-toggle,
  .tp-nav-item.is-open .tp-nav-toggle {
    color: #d8bb70;
    transform: rotate(180deg);
  }

  .tp-nav-popover {
    position: absolute;
    top: 5.15rem;
    left: 50%;
    display: grid;
    width: min(22rem, calc(100vw - 2rem));
    gap: 0.62rem;
    padding: 0.7rem;
    border: 1px solid rgba(190, 158, 88, 0.25);
    border-radius: 18px;
    background: rgba(248, 245, 238, 0.98);
    box-shadow: 0 24px 65px rgba(5, 15, 22, 0.26);
    color: #203440;
    opacity: 0;
    visibility: hidden;
    transform: translate3d(-50%, 10px, 0) scale(0.985);
    transition:
      opacity 180ms ease,
      visibility 180ms ease,
      transform 240ms var(--ease-soft);
  }

  .tp-nav-popover--group {
    left: auto;
    right: -6rem;
    width: min(30rem, calc(100vw - 2rem));
    transform: translate3d(0, 10px, 0) scale(0.985);
  }

  .tp-nav-item:hover .tp-nav-popover,
  .tp-nav-item:focus-within .tp-nav-popover,
  .tp-nav-item.is-open .tp-nav-popover {
    opacity: 1;
    visibility: visible;
    transform: translate3d(-50%, 0, 0) scale(1);
  }

  .tp-nav-item:hover .tp-nav-popover--group,
  .tp-nav-item:focus-within .tp-nav-popover--group,
  .tp-nav-item.is-open .tp-nav-popover--group {
    transform: translate3d(0, 0, 0) scale(1);
  }

  .tp-popover-intro {
    padding: 0.7rem 0.75rem 0.55rem;
    border-bottom: 1px solid rgba(32, 52, 64, 0.08);
  }

  .tp-popover-intro span {
    color: #a98238;
    font-size: 0.58rem;
    font-weight: 820;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .tp-popover-intro p {
    margin: 0.32rem 0 0;
    color: rgba(32, 52, 64, 0.62);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .tp-popover-links {
    display: grid;
    gap: 0.15rem;
  }

  .tp-popover-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 14px;
    padding: 0.72rem 0.78rem;
    color: #203440;
    transition: background 180ms ease, padding 220ms var(--ease-soft), color 180ms ease;
  }

  .tp-popover-links strong,
  .tp-agency-copy strong {
    display: block;
    font-size: 0.82rem;
    font-weight: 760;
    line-height: 1.2;
  }

  .tp-popover-links small,
  .tp-agency-copy small,
  .tp-agency-copy em {
    display: block;
    margin-top: 0.2rem;
    color: rgba(32, 52, 64, 0.55);
    font-size: 0.66rem;
    font-style: normal;
    line-height: 1.35;
  }

  .tp-popover-links b {
    color: #a98238;
    font-size: 0.75rem;
    transition: transform 180ms var(--ease-soft);
  }

  .tp-popover-links a:hover,
  .tp-popover-links a:focus-visible,
  .tp-agency-preview:hover,
  .tp-agency-preview:focus-visible {
    background: rgba(190, 158, 88, 0.12);
    color: #10202b;
  }

  .tp-popover-links a:hover {
    padding-left: 0.95rem;
  }

  .tp-popover-links a:hover b,
  .tp-popover-links a:focus-visible b {
    transform: translate(3px, -3px);
  }

  /* --- Interactive France Map Panel --- */
  .tp-agences-trigger {
    position: relative;
  }

  .tp-france-map-panel {
    max-height: 0;
    overflow: hidden;
    border-radius: 16px;
    opacity: 0;
    transition: max-height 380ms var(--ease-soft), opacity 280ms ease, margin 280ms ease;
    margin-top: 0;
  }

  .tp-france-map-panel.is-visible {
    max-height: 26rem;
    opacity: 1;
    margin-top: 0.5rem;
  }

  .tp-france-map-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid rgba(32, 52, 64, 0.1);
    border-radius: 16px;
    background: linear-gradient(145deg, #10202b 0%, #1a3040 100%);
    box-shadow: 0 18px 45px rgba(5, 15, 22, 0.22);
