---
import { franceMapPins, franceMapRoutes } from '../../data/france-map.data';
import type { Agency } from '../../types/agency';
interface Props { agencies: Agency[]; compact?: boolean; }
const { agencies, compact = false } = Astro.props;
const agencyBySlug = new Map(agencies.map((agency) => [agency.slug, agency]));
const referencePoints = franceMapPins.map((point) => {
  const agency = point.agencySlugs.map((slug) => agencyBySlug.get(slug)).find(Boolean);
  return {
    ...point,
    agency,
    city: point.city,
    region: point.region,
    href: agency ? `/agences/${agency.slug}` : point.href,
  };
});
---

<div class:list={['agency-map-layout', { compact }]}>
  <div class="map-intro">
    <p class="map-eyebrow">The Porters en France</p>
    <h2>Un contact proche,<br />où que commence votre mission.</h2>
    <p>Sélectionnez une ville pour découvrir son accompagnement, ses coordonnées confirmées et les modalités de rendez-vous.</p>
    <div class="map-legend"><span></span>Survolez un point · cliquez pour ouvrir l’agence</div>
  </div>
  <div class="map-stage" aria-label="Carte des agences The Porters en France">
    <img class="france-outline" src="/images/france-outline-source.svg" alt="Contour de la France métropolitaine" />
    <svg class="routes" viewBox="0 0 507 520" aria-hidden="true">
      {franceMapRoutes.map((route) => <path class:list={['route', `route-${route.id}`]} d={route.d} />)}
    </svg>
    {referencePoints.map((point, index) => {
      const agency = point.agency;
      return (
        <a class:list={['agency-point', `point-${point.id}`, `label-${point.labelSide || 'right'}`, { 'is-unconfirmed': !agency && point.status === 'À confirmer' }]} href={point.href} style={`--x:${point.x}%;--y:${point.y}%; --pin-delay:${index * 105}ms`} aria-label={agency ? `Découvrir l’agence ${point.city}` : `${point.city} - point de contact à confirmer`}>
          <span class="pin-ring"></span>
          <span class="pin-dot"></span>
          <span class="pulse"></span>
          <span class="agency-label">{point.city}</span>
          <span class="agency-card">
            <small>{point.region}</small><strong>{point.city}</strong>
            {agency?.address && <span>{agency.address}{agency.postalCode ? ` · ${agency.postalCode}` : ''}</span>}
            {agency && !agency.address && <span>Rendez-vous selon les modalités confirmées</span>}
            {!agency && <span>Présence historique à confirmer avant publication d’une page locale.</span>}
            <b>{agency ? 'Découvrir l’agence' : 'Voir les points confirmés'} →</b>
          </span>
        </a>
      );
    })}
  </div>
  <div class="agency-mobile-list">
    {agencies.map((agency) => <a href={`/agences/${agency.slug}`}><span><small>{agency.region}</small><strong>{agency.city}</strong></span><b>→</b></a>)}
  </div>
</div>

<style>
  .agency-map-layout {
    display: grid;
    grid-template-columns: minmax(19rem, 0.9fr) minmax(27rem, 1.1fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    padding: clamp(2rem, 5vw, 4.5rem);
    border-radius: 1.5rem;
    background: radial-gradient(circle at 76% 46%, rgba(198, 164, 90, 0.07), transparent 32%), #10202b;
    color: #fff;
    overflow: hidden;
  }
  .map-intro { position: relative; z-index: 2; }
  .map-eyebrow {
    margin-bottom: 1rem;
    color: #c6a45a;
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .map-intro h2 {
    max-width: 12ch;
    color: #fff;
    font-size: clamp(2.1rem, 3.4vw, 3.55rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }
  .map-intro > p:not(.map-eyebrow) {
    max-width: 29rem;
    margin-top: 1.4rem;
    color: rgba(255, 255, 255, 0.62);
    line-height: 1.7;
  }
  .map-legend {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 2rem;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.7rem;
  }
  .map-legend span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: #c6a45a;
    box-shadow: 0 0 0 6px rgba(198, 164, 90, 0.1);
  }

  .map-stage {
    position: relative;
    width: min(100%, 35rem);
    aspect-ratio: 507/520;
    margin: auto;
    animation: map-stage-enter 0.85s var(--ease-soft) both;
  }
  .france-outline, .routes {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 22px 45px rgba(0, 0, 0, 0.16));
  }
  .france-outline {
    opacity: 0.96;
    transform-origin: center;
    animation: map-outline-settle 1.1s 0.12s var(--ease-soft) both;
  }
  .routes { pointer-events: none; }
  .route {
    fill: none;
    stroke: rgba(198, 164, 90, 0.48);
    stroke-width: 1.35;
    stroke-dasharray: 5 8;
    stroke-linecap: round;
    animation: route 18s linear infinite;
  }
  .route-lyon { animation-duration: 21s; }
  .route-aix-marseille { animation-duration: 24s; }
  .route-montpellier { animation-duration: 19s; }
  .route-bordeaux { animation-duration: 22s; }

  .agency-point {
    position: absolute;
    left: var(--x);
    top: var(--y);
    z-index: 2;
    width: 1rem;
    height: 1rem;
    color: #fff;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.72);
    animation: pin-enter 0.55s var(--ease-soft) var(--pin-delay, 0ms) both;
  }

  .agency-label {
    position: absolute;
    top: 50%;
    left: calc(100% + 0.7rem);
    color: #d8bb70;
    font-size: clamp(0.7rem, 1.3vw, 1rem);
    font-weight: 780;
    letter-spacing: 0.09em;
    line-height: 1;
    text-shadow: 0 4px 18px rgba(0, 0, 0, 0.4);
    text-transform: uppercase;
    transform: translateY(-50%);
    transition: color 0.2s ease, transform 0.25s var(--ease-soft);
    white-space: nowrap;
  }

  .label-left .agency-label {
    right: calc(100% + 0.72rem);
    left: auto;
  }

  .label-top .agency-label {
    top: auto;
    bottom: calc(100% + 0.72rem);
    left: 50%;
    transform: translateX(-50%);
  }

  .label-bottom .agency-label {
    top: calc(100% + 0.72rem);
    left: 50%;
    transform: translateX(-50%);
  }
  
  .pin-ring {
    position: absolute;
    inset: 0;
    border: 2px solid #c6a45a;
    border-radius: 50%;
    background: #10202b;
    box-shadow: 0 0 0 3px rgba(198, 164, 90, 0.15);
    transition: 0.25s ease;
  }
  
  .pin-dot {
    position: absolute;
    inset: 3px;
    background: #c6a45a;
    border-radius: 50%;
    transition: 0.25s ease;
  }

  .is-unconfirmed .pin-ring {
    border-color: rgba(255, 255, 255, 0.4);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.08);
  }
  
  .is-unconfirmed .pin-dot {
    background: rgba(255, 255, 255, 0.4);
  }

  .is-unconfirmed .pulse { border-color: rgba(255, 255, 255, 0.22); }
  
  .pulse {
    position: absolute;
    inset: -0.35rem;
    border: 1px solid rgba(198, 164, 90, 0.5);
    border-radius: 50%;
    animation: pulse 2.4s ease-out infinite;
  }

  .agency-card {
    position: absolute;
    left: 1.5rem;
    bottom: 1.2rem;
    display: flex;
    width: 14rem;
    flex-direction: column;
    padding: 1rem;
    border: 1px solid rgba(198, 164, 90, 0.3);
    border-radius: 0.8rem;
    background: rgba(248, 245, 238, 0.97);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
    color: #203440;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px) scale(0.98);
    transition: 0.24s var(--ease-soft);
    pointer-events: none;
  }
  .point-lyon .agency-card, .point-aix-marseille .agency-card, .point-bordeaux .agency-card { right: 1.5rem; left: auto; }
  .point-lille .agency-card { top: 1.2rem; bottom: auto; }
  .point-montpellier .agency-card { left: -7rem; }
  
  .agency-card small { color: #a27c2f; font-size: 0.58rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .agency-card strong { margin-top: 0.15rem; font-size: 1.05rem; }
  .agency-card span { margin-top: 0.5rem; color: rgba(32, 52, 64, 0.62); font-size: 0.7rem; line-height: 1.45; }
  .agency-card b { margin-top: 0.8rem; color: #203440; font-size: 0.7rem; }
  
  .agency-point:hover, .agency-point:focus-visible { z-index: 8; }
  .agency-point:hover .pin-ring, .agency-point:focus-visible .pin-ring {
    transform: scale(1.38);
    box-shadow: 0 0 0 5px rgba(198, 164, 90, 0.2);
  }
  .agency-point:hover .pin-dot, .agency-point:focus-visible .pin-dot {
    transform: scale(1.38);
    background: #e0c476;
  }

  .agency-point:hover .agency-label,
  .agency-point:focus-visible .agency-label {
    color: #fff;
    transform: translateY(-50%) translateX(4px);
  }

  .label-left:hover .agency-label,
  .label-left:focus-visible .agency-label {
    transform: translateY(-50%) translateX(-4px);
  }
  
  .agency-point:hover .agency-card, .agency-point:focus-visible .agency-card {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  
  .map-stage:hover .route, .map-stage:hover .pulse { animation-play-state: paused; }
  .agency-mobile-list { display: none; }
  .compact { padding: clamp(2rem, 4vw, 3.5rem); }
  .compact .map-stage { max-width: 29rem; }
  
  @keyframes pulse { 0% { opacity: 0.8; transform: scale(0.7); } 70%, 100% { opacity: 0; transform: scale(2); } }
  @keyframes route { to { stroke-dashoffset: -190; } }
  @keyframes pin-enter { to { opacity: 1; transform: translate(-50%, -50%) scale(1); } }
  @keyframes map-stage-enter { from { opacity: 0; transform: translate3d(18px, 20px, 0) scale(0.985); } to { opacity: 1; transform: none; } }
  @keyframes map-outline-settle { from { opacity: 0; transform: scale(0.97); } to { opacity: 0.96; transform: scale(1); } }
  
  @media (max-width: 900px) {
    .agency-map-layout { grid-template-columns: 1fr; }
    .map-intro { text-align: center; }
    .map-intro > p:not(.map-eyebrow) { margin-inline: auto; }
    .map-legend { justify-content: center; }
    .map-stage { width: min(100%, 34rem); }
  }
  @media (max-width: 620px) {
    .agency-map-layout { padding: 2rem 1.1rem; border-radius: 1rem; }
    .map-stage { display: block; width: min(100%, 22rem); margin-top: 1rem; }
    .map-legend { display: none; }
    .agency-card { display: none; }
    .agency-mobile-list { display: grid; gap: 0.55rem; }
    .agency-mobile-list a { display: flex; align-items: center; justify-content: space-between; padding: 1rem; border: 1px solid rgba(255, 255, 255, 0.12); border-radius: 0.7rem; color: #fff; transition: 0.2s ease; }
    .agency-mobile-list a:active { border-color: #c6a45a; background: rgba(198, 164, 90, 0.1); transform: scale(0.99); }
    .agency-mobile-list span { display: flex; flex-direction: column; }
    .agency-mobile-list small { color: #c6a45a; font-size: 0.58rem; text-transform: uppercase; }
    .agency-mobile-list strong { margin-top: 0.15rem; }
    .agency-mobile-list b { color: #c6a45a; }
  }
  @media (prefers-reduced-motion: reduce) {
    .route, .pulse, .agency-point, .map-stage, .france-outline { animation: none; }
    .agency-point { opacity: 1; transform: translate(-50%, -50%); }
  }
</style>
