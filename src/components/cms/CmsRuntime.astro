---
// Every page keeps its rendered copy as an SEO-safe fallback. The runtime adds
// stable keys to unregistered visible text and then performs one request for
// the current route plus the shared header/footer content.
---

<script>
  import { supabase } from '../../lib/supabase';
  import type { CmsFormat } from '../../cms/content';

  type PublishedBlock = {
    content_key: string;
    route_path: string;
    element_type: string;
    published_content: string;
    published_format: CmsFormat;
    published_at: string;
  };

  type EditorBlock = PublishedBlock & {
    id: string;
    fallback_content: string;
    draft_content: string;
    draft_format: CmsFormat;
    status: 'draft' | 'published';
    published_version: number;
    updated_at: string;
  };

  const GLOBAL_ROUTE = '/_global';
  const candidateSelector = 'h1,h2,h3,h4,h5,h6,p,a,button,label,li,summary,blockquote,figcaption,strong,small,span';
  const excludedSelector = 'script,style,svg,noscript,template,[aria-hidden="true"],[data-cms-ignore]';
  const pageRoute = window.location.pathname.replace(/\/$/, '') || '/';
  const editorMode = new URLSearchParams(window.location.search).get('cms-editor') === '1';
  const blockByKey = new Map<string, PublishedBlock | EditorBlock>();
  let previewState: 'draft' | 'published' = editorMode ? 'draft' : 'published';

  function hashString(value: string) {
    let hash = 0x811c9dc5;
    for (let index = 0; index < value.length; index += 1) {
      hash ^= value.charCodeAt(index);
      hash = Math.imul(hash, 0x01000193);
    }
    return (hash >>> 0).toString(36);
  }

  function routeToken(route: string) {
    if (route === '/') return 'home';
    return route.slice(1).toLowerCase().replace(/[^a-z0-9/_-]+/g, '-').replaceAll('/', '.');
  }

  function nthOfType(element: Element) {
    let position = 1;
    let sibling = element.previousElementSibling;
    while (sibling) {
      if (sibling.tagName === element.tagName) position += 1;
      sibling = sibling.previousElementSibling;
    }
    return position;
  }

  function structuralPath(element: Element, root: Element) {
    const parts: string[] = [];
    let current: Element | null = element;
    while (current && current !== root) {
      parts.unshift(`${current.tagName.toLowerCase()}:${nthOfType(current)}`);
      current = current.parentElement;
    }
    return parts.join('/');
  }

  function elementType(element: Element) {
    const tag = element.tagName.toLowerCase();
    if (/^h[1-6]$/.test(tag)) return 'heading';
    if (tag === 'a' || tag === 'button' || tag === 'summary') return 'button';
    if (tag === 'label') return 'label';
    if (tag === 'li') return 'list_item';
    if (tag === 'blockquote') return 'quote';
    return 'paragraph';
  }

  function discoverEditableText() {
    const elements = Array.from(document.body.querySelectorAll<HTMLElement>(candidateSelector));
    const descriptors: Array<{ parent: HTMLElement; node: Text; key: string; route: string; type: string }> = [];

    elements.forEach((parent) => {
      if (parent.matches(excludedSelector) || parent.closest(excludedSelector)) return;
      if (parent.matches('[data-cms-key]') || parent.closest('[data-cms-key]')) return;

      const main = parent.closest('main');
      const header = main ? null : parent.closest('header');
      const footer = main ? null : parent.closest('footer');
      const root = header || footer || main || document.body;
      const scope = header ? 'global.header' : footer ? 'global.footer' : `pages.${routeToken(pageRoute)}`;
      const route = header || footer ? GLOBAL_ROUTE : pageRoute;
      const path = structuralPath(parent, root);
      let directTextIndex = 0;

      Array.from(parent.childNodes).forEach((node) => {
        if (node.nodeType !== Node.TEXT_NODE) return;
        const text = node.textContent || '';
        if (!/[A-Za-zÀ-ÖØ-öø-ÿ]/.test(text.trim())) return;
        directTextIndex += 1;
        const type = elementType(parent);
        const key = `${scope}.auto.${type}.${hashString(`${path}|text:${directTextIndex}`)}`;
        descriptors.push({ parent, node: node as Text, key, route, type });
      });
    });

    descriptors.forEach(({ parent, node, key, route, type }) => {
      if (!node.isConnected || parent.closest('[data-cms-key]')) return;
      const original = node.textContent || '';
      const leading = original.match(/^\s*/)?.[0] || '';
      const trailing = original.match(/\s*$/)?.[0] || '';
      const wrapper = document.createElement('span');
      wrapper.dataset.cmsKey = key;
      wrapper.dataset.cmsRoute = route;
      wrapper.dataset.cmsElementType = type;
      wrapper.dataset.cmsAuto = 'true';
      wrapper.dataset.cmsLeading = leading;
      wrapper.dataset.cmsTrailing = trailing;
      wrapper.textContent = original;
      node.replaceWith(wrapper);
    });
  }

  discoverEditableText();

  const formatAttributes = ['size', 'weight', 'alignment', 'color', 'line-height'] as const;

  function applyFormat(node: HTMLElement, format: CmsFormat = {}) {
    formatAttributes.forEach((attribute) => node.removeAttribute(`data-cms-format-${attribute}`));
    if (format.size && format.size !== 'default') node.dataset.cmsFormatSize = format.size;
    if (format.weight && format.weight !== 'default') node.dataset.cmsFormatWeight = format.weight;
    if (format.alignment && format.alignment !== 'default') node.dataset.cmsFormatAlignment = format.alignment;
    if (format.color && format.color !== 'default') node.dataset.cmsFormatColor = format.color;
    if (format.lineHeight && format.lineHeight !== 'default') node.dataset.cmsFormatLineHeight = format.lineHeight;
  }

  function applyValue(key: string, content: string, format: CmsFormat) {
    document.querySelectorAll<HTMLElement>('[data-cms-key]').forEach((node) => {
      if (node.dataset.cmsKey !== key) return;
      const leading = node.dataset.cmsAuto === 'true' ? node.dataset.cmsLeading || '' : '';
      const trailing = node.dataset.cmsAuto === 'true' ? node.dataset.cmsTrailing || '' : '';
      node.textContent = `${leading}${content}${trailing}`;
      applyFormat(node, format);

      const mirrorAttribute = node.dataset.cmsMirrorAttribute;
      if (mirrorAttribute) node.closest<HTMLElement>('[data-offer-step]')?.setAttribute(mirrorAttribute, content);
    });
  }

  function applyBlock(block: PublishedBlock | EditorBlock) {
    const draft = previewState === 'draft' && 'draft_content' in block;
    applyValue(
      block.content_key,
      draft ? block.draft_content : block.published_content,
      draft ? block.draft_format : block.published_format,
    );
  }

  function announceReady() {
    if (!editorMode) return;
    document.body.classList.add('cms-editor-mode');
    window.parent.postMessage({
      type: 'cms:ready',
      route: pageRoute,
      blocks: Array.from(blockByKey.values()),
    }, window.location.origin);
  }

  async function loadContent() {
    try {
      if (editorMode) {
        const { data: sessionData } = await supabase.auth.getSession();
        if (!sessionData.session) throw new Error('Session administrateur absente');

        const { data, error } = await supabase
          .from('cms_content_blocks')
          .select('id,content_key,route_path,element_type,fallback_content,draft_content,published_content,draft_format,published_format,status,published_version,updated_at,published_at')
          .in('route_path', [pageRoute, GLOBAL_ROUTE])
          .order('content_key');
        if (error) throw error;
        (data as EditorBlock[] | null)?.forEach((block) => blockByKey.set(block.content_key, block));
      } else {
        const { data, error } = await supabase
          .from('cms_published_content')
          .select('content_key,route_path,element_type,published_content,published_format,published_at')
          .in('route_path', [pageRoute, GLOBAL_ROUTE]);
        if (error) throw error;
        (data as PublishedBlock[] | null)?.forEach((block) => blockByKey.set(block.content_key, block));
      }

      blockByKey.forEach(applyBlock);
      announceReady();
    } catch (error) {
      console.warn('[CMS] Fallback content retained:', error);
      if (editorMode) {
        window.parent.postMessage({ type: 'cms:error', message: error instanceof Error ? error.message : 'Chargement impossible' }, window.location.origin);
      }
    }
  }

  if (editorMode) {
    document.addEventListener('click', (event) => {
      const clicked = event.target as HTMLElement;
      const target = clicked.closest<HTMLElement>('[data-cms-key]');
      if (target?.dataset.cmsKey) {
        event.preventDefault();
        event.stopPropagation();
        const block = blockByKey.get(target.dataset.cmsKey);
        if (!block) return;
        window.parent.postMessage({
          type: 'cms:select',
          key: target.dataset.cmsKey,
          route: target.dataset.cmsRoute,
          elementType: target.dataset.cmsElementType,
          block,
        }, window.location.origin);
        return;
      }

      const link = clicked.closest<HTMLAnchorElement>('a[href]');
      if (!link || link.hasAttribute('download')) return;
      const next = new URL(link.href, window.location.href);
      if (next.origin !== window.location.origin) {
        link.target = '_blank';
        link.rel = 'noreferrer';
        return;
      }
      if (next.pathname === pageRoute && next.hash) return;
      event.preventDefault();
      next.searchParams.set('cms-editor', '1');
      window.parent.postMessage({ type: 'cms:navigate-request', route: next.pathname, url: next.toString() }, window.location.origin);
    }, true);

    window.addEventListener('message', (event) => {
      if (event.origin !== window.location.origin || !event.data?.type) return;
      if (event.data.type === 'cms:update-preview') applyValue(event.data.key, event.data.content, event.data.format || {});
      if (event.data.type === 'cms:set-preview-state') {
        previewState = event.data.state === 'published' ? 'published' : 'draft';
        blockByKey.forEach(applyBlock);
      }
      if (event.data.type === 'cms:replace-block' && event.data.block) {
        blockByKey.set(event.data.block.content_key, event.data.block);
        applyBlock(event.data.block);
      }
      if (event.data.type === 'cms:navigate-approved' && typeof event.data.url === 'string') {
        const next = new URL(event.data.url, window.location.href);
        if (next.origin === window.location.origin) window.location.assign(next);
      }
      if (event.data.type === 'cms:reload') window.location.reload();
    });
  }

  void loadContent();
</script>

<style is:global>
  .cms-preserve-lines { white-space: pre-line; }

  [data-cms-format-size='small'][data-cms-element-type='heading'] { font-size: clamp(1.35rem, 2.5vw, 2.25rem) !important; }
  [data-cms-format-size='large'][data-cms-element-type='heading'] { font-size: clamp(2.5rem, 5vw, 5rem) !important; }
  [data-cms-format-size='xlarge'][data-cms-element-type='heading'] { font-size: clamp(3rem, 6.5vw, 6rem) !important; }
  [data-cms-format-size='small']:not([data-cms-element-type='heading']) { font-size: 0.78rem !important; }
  [data-cms-format-size='large']:not([data-cms-element-type='heading']) { font-size: 1.125rem !important; }
  [data-cms-format-size='xlarge']:not([data-cms-element-type='heading']) { font-size: 1.3rem !important; }
  [data-cms-format-weight='regular'] { font-weight: 400 !important; }
  [data-cms-format-weight='medium'] { font-weight: 500 !important; }
  [data-cms-format-weight='semibold'] { font-weight: 600 !important; }
  [data-cms-format-weight='bold'] { font-weight: 700 !important; }
  [data-cms-format-alignment='left'] { text-align: left !important; }
  [data-cms-format-alignment='center'] { text-align: center !important; }
  [data-cms-format-alignment='right'] { text-align: right !important; }
  [data-cms-format-color='navy'] { color: var(--color-porters-navy, #283743) !important; }
  [data-cms-format-color='gold'] { color: var(--color-porters-gold, #be9e58) !important; }
  [data-cms-format-color='dark'] { color: var(--color-porters-black, #0b1020) !important; }
  [data-cms-format-color='light'] { color: var(--color-porters-white, #faf8f3) !important; }
  [data-cms-format-color='muted'] { color: rgba(40, 55, 67, 0.62) !important; }
  [data-cms-format-line-height='compact'] { line-height: 1.08 !important; }
  [data-cms-format-line-height='normal'] { line-height: 1.4 !important; }
  [data-cms-format-line-height='relaxed'] { line-height: 1.75 !important; }

  body.cms-editor-mode [data-cms-key] {
    border-radius: 3px;
    cursor: pointer !important;
    outline: 1px dashed rgba(190, 158, 88, 0.58);
    outline-offset: 3px;
    transition: outline-color 160ms ease, box-shadow 160ms ease;
  }

  body.cms-editor-mode [data-cms-key]:hover,
  body.cms-editor-mode [data-cms-key]:focus {
    outline: 2px solid #be9e58;
    box-shadow: 0 0 0 5px rgba(190, 158, 88, 0.15);
  }
</style>
